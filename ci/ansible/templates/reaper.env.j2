# /etc/mothertree-reaper.env — sourced by /usr/local/bin/dev-reaper.sh on
# every cron tick. Managed by Ansible (ci/ansible/templates/reaper.env.j2).
# Mode 0600, owner root, group root.

# How long the cluster must be idle (no heartbeat write, no held pool lease)
# before the reaper destroys it. Fractional hours are accepted for testing.
IDLE_HOURS={{ reaper_idle_hours | default(2) }}

# On-demand-dev heartbeat bucket. The bucket is provisioned by phase1-dev/
# (`linode_object_storage_bucket "dev_state"`); credentials are scoped to it
# with read_write permission. Operator captures these values from
# `terraform-outputs.dev.env` after the phase1-dev migration and puts them
# in the Ansible vault.
DEV_STATE_BUCKET={{ dev_state_bucket }}
DEV_STATE_S3_ENDPOINT={{ dev_state_s3_endpoint }}
DEV_STATE_S3_KEY={{ dev_state_s3_key }}
DEV_STATE_S3_SECRET={{ dev_state_s3_secret }}

# Valkey holds the per-pool tenant leases. The reaper checks both
# ci-lease-pool1 and ci-lease-pool2 before destroying — if either exists,
# a pipeline is mid-flight.
VALKEY_HOST=127.0.0.1
VALKEY_PORT=6379
VALKEY_PASSWORD={{ valkey_password }}

# Reaper-owned checkout. The reaper pulls latest master into here before each
# run so it always invokes the latest destroy-dev-cluster.sh.
REPO_DIR=/home/woodpecker/mothertree-checkout

# Linode API token (`personal access token` scope: read_write on LKE + Object
# Storage + VPC + linodes). The reaper passes this through to linode-cli and
# to terraform (as TF_VAR_linode_token via the generated secrets.tfvars.env).
LINODE_CLI_TOKEN={{ linode_token }}

# Phase1-dev Terraform state backend credentials. These are scoped to the
# `mothertree-tf-state-dev` bucket only — separate from the heartbeat bucket
# credentials above. Operator stores them in lpass entry
# `mothertree-tf-state-dev-s3-credentials` during the phase1-dev migration
# (see phase1-dev/MIGRATION.md) and copies them into the Ansible vault.
AWS_ACCESS_KEY_ID={{ tf_state_aws_access_key_id }}
AWS_SECRET_ACCESS_KEY={{ tf_state_aws_secret_access_key }}
