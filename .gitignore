# Terraform
*.tfstate
*.tfstate.*
*.tfplan
.terraform/
.terraform.lock.hcl
terraform.tfvars
*.tfvars
*.tfvars.json
*.tfvars.env
secrets.tfvars.env

# Terraform-generated OpenVPN configs (contain real domain, regenerated by terraform apply)
phase1/openvpn-server.*.conf
phase1/openvpn-client-template.*.conf

# Kubernetes
kubeconfig.*.yaml
*.kubeconfig

# Environment files
.env
*.env
# But track docs/envs/*.env (non-secret domain/host configuration)
!docs/envs/*.env
# Track image version config (not a secret — just semver tags)
!apps/image-versions.env

# Logs
*.log
logs/
crash.log
crash.*.log

# Node.js
node_modules/

# Build artifacts
.source-hash.*
coverage/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode/
.idea/
.cursor/
.cursorrules
*.swp
*.swo

# Temporary files
*.tmp
*.temp
kubetmp/

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info
.terraformrc
terraform.rc

# Performance test artifacts
tf
perf/users/**

# CI Ansible inventory (contains real IPs, generated by provision-ci.sh)
ci/ansible/inventory.yml
# CI Ansible vars (contains credentials — primary location is config/platform/ci/)
ci/ansible/ansible-vars.yml

# Secrets (sensitive credentials)
matrix-registration-shared-secret.txt
docs/keycloak-google-oauth-secret.yaml
apps/manifests/jitsi/secrets.yaml

# Tenant secrets (sensitive credentials per tenant/environment)
tenants/*/*.secrets.yaml
config/tenants/*/*.secrets.yaml
*.secrets.yaml

# E2E test artifacts
e2e/node_modules/
e2e/.auth/
e2e/test-results/
e2e/playwright-report/
e2e/blob-report/
e2e/.env
