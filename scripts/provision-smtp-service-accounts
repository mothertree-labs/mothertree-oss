#!/bin/bash

# Provision SMTP service-account principals in the tenant's Stalwart plus
# per-caller `smtp-credentials` K8s Secrets.
#
# Five service accounts are created per tenant (idempotent):
#   account-portal-smtp@<email_domain>  → tn-<tenant>-admin
#   admin-portal-smtp@<email_domain>    → tn-<tenant>-admin
#   docs-smtp@<email_domain>            → tn-<tenant>-docs
#   synapse-smtp@<email_domain>         → tn-<tenant>-matrix
#   nextcloud-smtp@<email_domain>       → tn-<tenant>-files
#
# Each caller's namespace receives a Secret named `smtp-credentials` with keys:
#   SMTP_HOST, SMTP_PORT, SMTP_USERNAME, SMTP_PASSWORD
#
# Usage:
#   ./scripts/provision-smtp-service-accounts -e <env> -t <tenant> [--rotate]
#
# Options:
#   -e <env>     Environment (dev, prod, prod-eu)
#   -t <tenant>  Tenant name
#   --rotate     Force a new password for every caller (old one is removed)

set -euo pipefail

REPO_ROOT="${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "${REPO_ROOT}/scripts/lib/common.sh"
source "${REPO_ROOT}/scripts/lib/args.sh"

mt_usage() {
  echo "Usage: $0 -e <env> -t <tenant> [--rotate]"
  echo ""
  echo "Provision SMTP service-account principals in Stalwart and write"
  echo "per-caller smtp-credentials K8s Secrets."
  echo ""
  echo "Options:"
  echo "  -e <env>     Environment (e.g., dev, prod, prod-eu)"
  echo "  -t <tenant>  Tenant name (e.g., example)"
  echo "  --rotate     Rotate all app passwords (delete existing, create new)"
  echo "  -h, --help   Show this help"
}

mt_parse_args "$@"
mt_require_env
mt_require_tenant

ROTATE_FLAG="false"
if mt_has_flag "--rotate"; then
  ROTATE_FLAG="true"
fi

# Load project + tenant config
source "${REPO_ROOT}/scripts/lib/paths.sh"
_mt_resolve_project_conf
[[ -n "${MT_PROJECT_CONF:-}" ]] && source "$MT_PROJECT_CONF"
source "${REPO_ROOT}/scripts/lib/config.sh"
mt_load_tenant_config

# Fail fast on missing required values (CLAUDE.md fail-fast rule).
: "${KUBECONFIG:?KUBECONFIG must be set}"
: "${NS_STALWART:?NS_STALWART must be set (tenant mail namespace)}"
: "${NS_ADMIN:?NS_ADMIN must be set}"
: "${NS_DOCS:?NS_DOCS must be set}"
: "${NS_MATRIX:?NS_MATRIX must be set}"
: "${NS_FILES:?NS_FILES must be set}"
: "${EMAIL_DOMAIN:?EMAIL_DOMAIN must be set}"
: "${STALWART_ADMIN_PASSWORD:?STALWART_ADMIN_PASSWORD must be set (tenant secrets .stalwart.admin_password)}"
: "${MT_TENANT:?MT_TENANT must be set}"

if ! command -v node >/dev/null 2>&1; then
  print_error "node is required on PATH (uses global fetch; Node 18+)."
  exit 1
fi

# Verify Stalwart is running before we try to port-forward.
if ! kubectl --kubeconfig "$KUBECONFIG" -n "$NS_STALWART" get svc stalwart >/dev/null 2>&1; then
  print_error "Stalwart service not found in namespace $NS_STALWART. Run deploy-stalwart.sh first."
  exit 1
fi

# Port-forward to Stalwart API. Caller can skip by setting STALWART_API_URL directly.
if [ -z "${STALWART_API_URL:-}" ]; then
  LOCAL_PORT="${STALWART_PROVISION_LOCAL_PORT:-18092}"
  PF_LOG=$(mktemp)
  print_status "Port-forwarding svc/stalwart:8080 → localhost:${LOCAL_PORT}"
  kubectl --kubeconfig "$KUBECONFIG" -n "$NS_STALWART" port-forward svc/stalwart "${LOCAL_PORT}:8080" >"$PF_LOG" 2>&1 &
  PF_PID=$!
  cleanup() {
    kill "$PF_PID" 2>/dev/null || true
    rm -f "$PF_LOG"
  }
  trap cleanup EXIT
  # Wait for port-forward to become responsive (admin endpoint requires auth — 401 also means "up").
  for _i in {1..20}; do
    code=$(curl -s -o /dev/null -w '%{http_code}' --max-time 2 "http://localhost:${LOCAL_PORT}/api/principal?limit=1" || true)
    if [ "$code" = "200" ] || [ "$code" = "401" ] || [ "$code" = "403" ]; then
      break
    fi
    sleep 1
  done
  STALWART_API_URL="http://localhost:${LOCAL_PORT}"
fi

export STALWART_API_URL
export STALWART_ADMIN_PASSWORD
export EMAIL_DOMAIN
export MT_TENANT
export NS_STALWART NS_ADMIN NS_DOCS NS_MATRIX NS_FILES
export KUBECONFIG
export ROTATE="$ROTATE_FLAG"

# The Node helper exits:
#   0  — something was provisioned or rotated (callers need a rollout restart)
#   2  — nothing changed (skip restarts to preserve the conditional-restart
#        invariant — see CLAUDE.md "Conditional Restart System")
#   1  — error
set +e
node "${REPO_ROOT}/scripts/lib/provision-smtp.js"
rc=$?
set -e

case "$rc" in
  0)
    print_success "SMTP service accounts provisioned for tenant $MT_TENANT (changed)"
    exit 0
    ;;
  2)
    print_status "SMTP service accounts already up to date for tenant $MT_TENANT"
    # Preserve the "unchanged" signal for the shell caller.
    exit 2
    ;;
  *)
    print_error "provision-smtp failed (exit $rc)"
    exit "$rc"
    ;;
esac
