# Create Keycloak theme ConfigMap BEFORE deploying Keycloak.
# Track whether the ConfigMap actually changed so we can conditionally restart
# Keycloak below — unnecessary restarts destroy all user sessions (Infinispan).
print_status "Creating Keycloak theme ConfigMap..."
mt_reset_change_tracker
THEMES_DIR="$REPO_ROOT/apps/themes"
if [ -d "$THEMES_DIR/platform" ]; then
  print_status "Packaging platform theme..."
  TMP_TAR=$(mktemp /tmp/platform-theme-XXXXXX.tar.gz)
  pushd "$THEMES_DIR" >/dev/null
    tar -czf "$TMP_TAR" platform
  popd >/dev/null

  kubectl -n "$NS_AUTH" create configmap keycloak-platform-theme \
      --from-file=theme.tar.gz="$TMP_TAR" \
      --dry-run=client -o yaml | mt_apply kubectl apply -f -
  rm -f "$TMP_TAR"
  print_status "Platform theme ConfigMap created in namespace $NS_AUTH"
else
  print_warning "Theme directory not found at $THEMES_DIR/platform, skipping theme ConfigMap"
fi

# PgBouncer is the sole database entrypoint (connects to external PG VM via Tailscale mesh)
export PG_SERVICE_NAME="pgbouncer"
export PG_HOST="${PG_SERVICE_NAME}.${NS_DB}.svc.cluster.local"
print_status "PostgreSQL: using PgBouncer at $PG_HOST (external PG VM via Tailscale mesh)"

# Verify shared infra secrets were loaded by infra-config.sh
# (KEYCLOAK_ADMIN_PASSWORD, KEYCLOAK_DB_PASSWORD, TF_VAR_grafana_admin_password)
if [ -z "${KEYCLOAK_ADMIN_PASSWORD:-}" ] || [ "${KEYCLOAK_ADMIN_PASSWORD}" = "null" ] || \
   [ -z "${KEYCLOAK_DB_PASSWORD:-}" ] || [ "${KEYCLOAK_DB_PASSWORD}" = "null" ]; then
  print_error "Keycloak admin/DB passwords not loaded by infra-config.sh"
  print_error "Add keycloak.admin_password and keycloak.db_password to tenants/$INFRA_TENANT_NAME/${MT_ENV}.secrets.yaml"
  exit 1
fi

# NOTE: Keycloak DB password is managed on the external PG VM (created by Ansible).
# No in-cluster password sync needed — PgBouncer uses auth_query to authenticate.

# Deploy Keycloak (connects to PG VM via PgBouncer)
print_status "Deploying Keycloak to $NS_AUTH namespace (replicas: $KEYCLOAK_REPLICAS)..."
pushd "$REPO_ROOT/apps" >/dev/null
  helmfile -e "$MT_ENV" -l name=keycloak sync --skip-deps
popd >/dev/null

# Conditionally restart Keycloak only when theme ConfigMap actually changed.
# The init container extracts the theme tar.gz on startup, so a restart is needed
# when theme files change — but unnecessary restarts destroy all user sessions
# (sessions live in Infinispan in-memory cache; persistent-user-sessions is not enabled).
mt_restart_if_changed statefulset/keycloak-keycloakx -n "$NS_AUTH"

# Always wait for rollout to complete — helmfile sync above may have triggered a
# rolling update even if we didn't explicitly restart (e.g., chart value changes).
# This returns immediately if no rollout is in progress.
kubectl -n "$NS_AUTH" rollout status statefulset/keycloak-keycloakx --timeout=300s

# Cold-start gate: confirm Keycloak's OIDC discovery is actually serving.
# Pod-Ready + rollout-complete is necessary but not sufficient — Keycloak takes
# another 30-90s after pod-Ready to fully boot the realm and start serving
# /.well-known/openid-configuration. Downstream callers (admin-portal,
# ci-lease-tenant, every OIDC client) will 503 if they hit Keycloak in this
# window. Master realm covers the full HTTP stack; tenant realms are checked
# per-tenant by create_env.
mt_wait_for_keycloak_oidc master

# Sync Keycloak admin password.
# The KEYCLOAK_ADMIN_PASSWORD env var only applies on first boot; afterwards the
# password is stored in Keycloak's database. We use kcadm.sh to verify/update it,
# handling credential rotation and migration from legacy hardcoded passwords.
print_status "Waiting for Keycloak to be ready before syncing admin password..."
kubectl wait --for=condition=ready pod/keycloak-keycloakx-0 -n "$NS_AUTH" \
  --kubeconfig="$KUBECONFIG" --timeout=180s 2>/dev/null || true

print_status "Syncing Keycloak admin password..."
if kubectl exec keycloak-keycloakx-0 -n "$NS_AUTH" -c keycloak \
    --kubeconfig="$KUBECONFIG" -- \
    /opt/keycloak/bin/kcadm.sh config credentials \
    --server http://localhost:8080 --realm master \
    --user admin --password "$KEYCLOAK_ADMIN_PASSWORD" 2>/dev/null; then
  print_status "Keycloak admin password already matches secrets file"
else
  LEGACY_PASSWORDS=("keycloak-admin-password-change-me" "admin" "changeme")
  ADMIN_UPDATED=false
  for old_pass in "${LEGACY_PASSWORDS[@]}"; do
    if kubectl exec keycloak-keycloakx-0 -n "$NS_AUTH" -c keycloak \
        --kubeconfig="$KUBECONFIG" -- \
        /opt/keycloak/bin/kcadm.sh config credentials \
        --server http://localhost:8080 --realm master \
        --user admin --password "$old_pass" 2>/dev/null; then
      print_status "Authenticated with legacy password, updating to new password..."
      kubectl exec keycloak-keycloakx-0 -n "$NS_AUTH" -c keycloak \
          --kubeconfig="$KUBECONFIG" -- \
          /opt/keycloak/bin/kcadm.sh set-password \
          --server http://localhost:8080 --realm master \
          --username admin --new-password "$KEYCLOAK_ADMIN_PASSWORD" 2>/dev/null && \
        print_status "Keycloak admin password updated successfully" && ADMIN_UPDATED=true
      break
    fi
  done
  if [ "$ADMIN_UPDATED" != "true" ]; then
    print_warning "Could not sync Keycloak admin password — manual reset may be needed"
  fi
fi

# NOTE: DNS records are now managed by manage_infra --dns (via scripts/manage-dns.sh)
# NOTE: LKE firewall rules are now managed by manage_infra --firewall. See issue #244.

# =============================================================================
# External-DNS alias record — the ONE infra DNS record CI must own
# =============================================================================
# #244 moved infra DNS to the operator-run `manage_infra --dns` phase, but the
# external-DNS CNAME alias is a special case that must be reconciled by code on
# every deploy (no manual step): tenants whose DNS zone we do NOT control
# (dns_external=true) point their service CNAMEs at
# `lb1.prod.<infra-domain>`, which MUST be a DNS-only CNAME to the prod-eu
# ingress alias `lb1.prod-eu.<infra-domain>`. If it is Cloudflare-proxied, the
# foreign-zone TLS handshake fails (proxy serves the wrong cert) and ACME
# HTTP-01 cannot reach our origin — so the un-proxy here is what makes a
# dns_external tenant's traffic + cert issuance work. Reconciling it in CI means
# the tenant's remaining CNAMEs are the only thing left for them to do.
# Idempotent: create_dns_record PUTs the record and normalises a stale
# proxied/A record into the DNS-only CNAME. Scoped to prod-eu (where
# external-DNS tenants are hosted); manage-dns.sh still defines the same record
# for the operator path, and both write the identical value.
if [ "$MT_ENV" = "prod-eu" ]; then
  print_status "Reconciling external-DNS alias: lb1.prod.${INFRA_DOMAIN} -> lb1.prod-eu.${INFRA_DOMAIN} (DNS-only)"

  # Infra-zone Cloudflare creds. Prefer infra-config's exported values; fall
  # back to the cluster cert-manager token (deployed earlier in this script) and
  # a zone-id lookup, so this works even when the infra secrets carry no CF creds.
  if [ -z "${TF_VAR_cloudflare_api_token:-}" ]; then
    TF_VAR_cloudflare_api_token="$(kubectl get secret cloudflare-api-token -n "$NS_CERTMANAGER" \
      -o jsonpath='{.data.api-token}' 2>/dev/null | base64 -d 2>/dev/null || true)"
  fi
  : "${TF_VAR_cloudflare_api_token:?No Cloudflare API token for the infra zone (TF_VAR_cloudflare_api_token unset and cloudflare-api-token secret in $NS_CERTMANAGER empty/missing). Cannot reconcile the external-DNS alias.}"

  if [ -z "${TF_VAR_cloudflare_zone_id:-}" ]; then
    TF_VAR_cloudflare_zone_id="$(curl -s -X GET \
      "https://api.cloudflare.com/client/v4/zones?name=${INFRA_DOMAIN}" \
      -H "Authorization: Bearer ${TF_VAR_cloudflare_api_token}" \
      -H "Content-Type: application/json" | jq -r '.result[0].id // empty')"
  fi
  : "${TF_VAR_cloudflare_zone_id:?Could not resolve the Cloudflare zone id for ${INFRA_DOMAIN}. Cannot reconcile the external-DNS alias.}"

  export TF_VAR_cloudflare_api_token TF_VAR_cloudflare_zone_id
  source "${REPO_ROOT}/scripts/lib/dns.sh"
  create_dns_record "lb1.prod.${INFRA_DOMAIN}" "CNAME" "lb1.prod-eu.${INFRA_DOMAIN}" "false"
fi

# =============================================================================
# Deploy K8s Postfix (ConfigMaps, Deployment, Services, NetworkPolicy)
# =============================================================================
# Gate on whether any tenant in this env has mail enabled — prod and dev both
# have tenants with mail, while prod-eu currently doesn't. SES credentials are
# orthogonal (prod has them, dev direct-sends without SES).
_mail_enabled_any=false
source "${REPO_ROOT}/scripts/lib/paths.sh"
_mt_resolve_tenants_dir
for _tdir in "$MT_TENANTS_DIR"/*/; do
  _tcfg="${_tdir}/${MT_ENV}.config.yaml"
  [ -f "$_tcfg" ] || continue
  if [ "$(yq '.features.mail_enabled // false' "$_tcfg")" = "true" ]; then
    _mail_enabled_any=true
    break
  fi
done

if [ "$_mail_enabled_any" = "true" ]; then
  print_status "Deploying K8s Postfix..."
  if [ -x "$REPO_ROOT/apps/deploy-postfix.sh" ]; then
    "$REPO_ROOT/apps/deploy-postfix.sh" -e "$MT_ENV" --nesting-level=$((MT_NESTING_LEVEL+1)) 2>&1 | sed 's/^/  /'
  else
    print_error "deploy-postfix.sh not found"
    exit 1
  fi

  # =============================================================================
  # Configure K8s Postfix mail routing using shared script
  # =============================================================================
  print_status "Configuring K8s Postfix mail routing..."
  if [ -x "$REPO_ROOT/scripts/configure-mail-routing" ]; then
    "$REPO_ROOT/scripts/configure-mail-routing" -e "$MT_ENV" --nesting-level=$((MT_NESTING_LEVEL+1)) 2>&1 | sed 's/^/  /'
  else
    print_warning "configure-mail-routing script not found"
  fi

  # =============================================================================
  # Configure nginx TCP proxy for inbound SMTP (port 25 -> Postfix:25)
  # =============================================================================
  # Inbound MX traffic: internet → NodeBalancer:25 → nginx:25 → infra-mail/postfix:25.
  # The Linode NodeBalancer adds PROXY protocol v2 headers (via the
  # linode-loadbalancer-default-proxy-protocol annotation on the ingress service),
  # so nginx sees real client IPs via PROXY.
  # Two things are needed:
  #   1. tcp-services ConfigMap entries (tells nginx where to proxy)
  #   2. LB service ports (tells the cloud LB to forward to nginx's NodePort)
  print_status "Configuring nginx TCP proxy for Postfix inbound SMTP..."

  if ! kubectl get configmap tcp-services -n "$NS_INGRESS" >/dev/null 2>&1; then
    print_status "Creating tcp-services ConfigMap..."
    kubectl create configmap tcp-services -n "$NS_INGRESS"
  fi

  # Migrate any stale "30025" entry (from the pre-relay-VM-removal era) to port 25
  if kubectl get configmap tcp-services -n "$NS_INGRESS" -o jsonpath='{.data.30025}' 2>/dev/null | grep -q .; then
    print_status "Removing stale tcp-services entry for port 30025..."
    kubectl patch configmap tcp-services -n "$NS_INGRESS" --type=json \
      -p='[{"op": "remove", "path": "/data/30025"}]' || true
  fi

  # NOTE: port 25 does NOT use PROXY protocol (see apps/values/ingress-nginx.yaml for
  # the rationale). Linode's PROXY v2 to nginx hangs specifically on port 25; disabling
  # it is the workaround. Postfix sees nginx pod IPs instead of real client IPs.
  kubectl patch configmap tcp-services -n "$NS_INGRESS" --type merge -p '{"data": {"25": "infra-mail/postfix:25"}}'
  print_status "tcp-services ConfigMap updated with 25 -> infra-mail/postfix:25 (no PROXY)"

  EXISTING_PORTS=$(kubectl get svc ingress-nginx-controller -n "$NS_INGRESS" -o jsonpath='{.spec.ports[*].port}' 2>/dev/null || echo "")
  # Remove stale 30025 port from LB service (from the pre-relay-VM-removal era)
  if echo "$EXISTING_PORTS" | grep -qw "30025"; then
    print_status "Removing stale port 30025 from ingress-nginx LB service..."
    STALE_INDEX=$(kubectl get svc ingress-nginx-controller -n "$NS_INGRESS" \
      -o json | jq '.spec.ports | to_entries | map(select(.value.port == 30025)) | .[0].key // empty')
    if [ -n "$STALE_INDEX" ]; then
      kubectl patch svc ingress-nginx-controller -n "$NS_INGRESS" --type='json' \
        -p="[{\"op\": \"remove\", \"path\": \"/spec/ports/${STALE_INDEX}\"}]" || true
    fi
  fi
  # Re-fetch after possible stale-port removal
  EXISTING_PORTS=$(kubectl get svc ingress-nginx-controller -n "$NS_INGRESS" -o jsonpath='{.spec.ports[*].port}' 2>/dev/null || echo "")
  if ! echo "$EXISTING_PORTS" | grep -qw "25"; then
    print_status "Adding port 25 (smtp-inbound) to ingress-nginx LB service..."
    kubectl patch svc ingress-nginx-controller -n "$NS_INGRESS" --type='json' \
      -p='[{"op": "add", "path": "/spec/ports/-", "value": {"name": "smtp-inbound", "port": 25, "targetPort": 25, "protocol": "TCP"}}]'
  else
    print_status "Port 25 already present on ingress-nginx LB service"
  fi
else
  print_status "Skipping K8s Postfix (no tenant has features.mail_enabled=true in $MT_ENV)"
fi

# NOTE: VPN route DaemonSet removed — replaced by Tailscale mesh (Headscale).
# NOTE: Ansible (TURN, Headscale, PostgreSQL) is managed by manage_infra --ansible.

# Wait for linkeditor build that was started in background at the beginning
if [ -n "$LINKEDITOR_BUILD_PID" ]; then
  print_status "Waiting for files_linkeditor build to complete..."
  if wait $LINKEDITOR_BUILD_PID; then
    print_success "files_linkeditor app built"
  else
    print_warning "files_linkeditor build may have failed. Check /tmp/linkeditor-build.log"
    cat /tmp/linkeditor-build.log 2>/dev/null | tail -20 || true
  fi
elif [ -d "$REPO_ROOT/submodules/files_linkeditor" ]; then
  if [ -f "$REPO_ROOT/scripts/build-linkeditor.sh" ]; then
    print_status "Building files_linkeditor Nextcloud app..."
    "$REPO_ROOT/scripts/build-linkeditor.sh" --nesting-level=$((MT_NESTING_LEVEL+1))
    print_success "files_linkeditor app built"
  else
    print_warning "build-linkeditor.sh not found, skipping files_linkeditor build"
  fi
else
  print_status "files_linkeditor submodule not found, skipping (optional component)"
fi

# =============================================================================
