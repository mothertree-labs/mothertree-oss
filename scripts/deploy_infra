#!/bin/bash

# Deploy Shared Infrastructure Components (pure K8s — CI-able)
# Purpose: Deploy shared Kubernetes infrastructure that all tenants use
#
# This script deploys:
#   - Ingress controllers (public and internal)
#   - Cert-manager for TLS certificates
#   - Monitoring stack (Prometheus, Grafana, Vector)
#   - PostgreSQL (shared database)
#   - Keycloak (shared authentication)
#   - Postfix SMTP server (via deploy-postfix.sh)
#   - nginx TCP proxy for SMTP
#   - VPN route DaemonSet
#
# Does NOT require: VPN connectivity, Ansible, Linode API (except CFW K8s secret)
# For VPN/Ansible/firewall, use: ./scripts/manage_infra -e <env>
#
# Run this ONCE per environment, not per tenant.
# For tenant deployments, use: ./scripts/create_env -e <env> -t <tenant>
#
# Usage:
#   ./scripts/deploy_infra -e <env>
#   ./scripts/deploy_infra <env>    (backward compat)
#
# Examples:
#   ./scripts/deploy_infra -e prod
#   ./scripts/deploy_infra dev

set -euo pipefail

REPO_ROOT="${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "${REPO_ROOT}/scripts/lib/common.sh"
source "${REPO_ROOT}/scripts/lib/args.sh"

mt_usage() {
  echo "Usage: $0 -e <env>"
  echo ""
  echo "Deploy shared infrastructure components for an environment."
  echo ""
  echo "Options:"
  echo "  -e <env>       Environment (e.g., dev, prod)"
  echo "  -h, --help     Show this help"
  echo ""
  echo "Examples:"
  echo "  $0 -e prod    # Deploy infrastructure for production"
  echo "  $0 -e dev     # Deploy infrastructure for development"
}

mt_parse_args "$@"
mt_require_env

# Load all infrastructure configuration
source "${REPO_ROOT}/scripts/lib/infra-config.sh"
mt_load_infra_config

source "${REPO_ROOT}/scripts/lib/notify.sh"
mt_deploy_start "deploy_infra"

mt_require_commands kubectl helm helmfile yq jq curl openssl

# Validate Cloudflare IP ranges before deploying (firewall rules depend on these)
print_status "Validating Cloudflare IP ranges..."
"$REPO_ROOT/scripts/check-cloudflare-ips" || { print_error "Cloudflare IPs changed. Run: ./scripts/check-cloudflare-ips --update"; exit 1; }

print_status "Deploying shared infrastructure for environment: $MT_ENV"
print_status "Kubeconfig: $KUBECONFIG"

# Source project config if available (provides CONTAINER_REGISTRY, GITHUB_ORG)
source "${REPO_ROOT}/scripts/lib/paths.sh"
_mt_resolve_project_conf
[[ -n "$MT_PROJECT_CONF" ]] && source "$MT_PROJECT_CONF"

# Create infrastructure namespaces
print_status "Creating infrastructure namespaces..."
for ns in $NS_DB $NS_AUTH $NS_MONITORING $NS_INGRESS $NS_INGRESS_INTERNAL $NS_CERTMANAGER $NS_MAIL; do
  kubectl create namespace "$ns" 2>/dev/null || print_status "Namespace $ns already exists"
done

# =============================================================================
# Consolidate helm repo updates (done once here, skipped in later steps)
# =============================================================================
print_status "Updating helm repositories (consolidated)..."
helm repo add bitnami https://charts.bitnami.com/bitnami 2>/dev/null || true
helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx 2>/dev/null || true
helm repo add jetstack https://charts.jetstack.io 2>/dev/null || true
helm repo add prometheus-community https://prometheus-community.github.io/helm-charts 2>/dev/null || true
helm repo add vector https://helm.vector.dev 2>/dev/null || true
helm repo add codecentric https://codecentric.github.io/helm-charts 2>/dev/null || true
helm repo add metrics-server https://kubernetes-sigs.github.io/metrics-server/ 2>/dev/null || true
helm repo add linode-cfw https://linode.github.io/cloud-firewall-controller 2>/dev/null || true
helm repo update >/dev/null 2>&1 &
HELM_REPO_UPDATE_PID=$!
print_status "Helm repo update started in background (PID: $HELM_REPO_UPDATE_PID)"

# =============================================================================
# Start linkeditor build early (runs in background while other work proceeds)
# =============================================================================
LINKEDITOR_BUILD_PID=""
if [ -d "$REPO_ROOT/submodules/files_linkeditor" ] && [ -f "$REPO_ROOT/scripts/build-linkeditor.sh" ]; then
  print_status "Starting files_linkeditor build in background..."
  "$REPO_ROOT/scripts/build-linkeditor.sh" --nesting-level=$((MT_NESTING_LEVEL+1)) > /tmp/linkeditor-build.log 2>&1 &
  LINKEDITOR_BUILD_PID=$!
  print_status "files_linkeditor build started (PID: $LINKEDITOR_BUILD_PID)"
fi

# Wait for helm repo update before first helm command
print_status "Waiting for helm repo update to complete..."
wait $HELM_REPO_UPDATE_PID 2>/dev/null || true
print_status "Helm repo update complete"

# =============================================================================
# Internal ingress allowlist (stable CIDRs; not dependent on node churn)
# =============================================================================
# The internal ingress is exposed via NodePort and is reachable via VPN.
# VPN-to-cluster traffic may be NAT'd through different private subnets over time
# (VPN server subnet changes, node pool churn). Enumerating current node /24s is
# brittle and leads to unexpected 403s. We allow:
#   - VPN_NETWORK_CIDR: VPN client network (10.8.0.0/24 prod, 10.9.0.0/24 dev)
#   - 192.168.0.0/16: Linode private networking range (covers VPN/private subnets)
#   - 10.2.0.0/16: pod CIDR (Linode LKE default)
print_status "Setting internal ingress whitelist CIDRs (stable)..."

STABLE_CIDRS="${VPN_NETWORK_CIDR:-10.8.0.0/24},192.168.0.0/16,10.2.0.0/16"
export INGRESS_INTERNAL_WHITELIST="$STABLE_CIDRS"
export INGRESS_INTERNAL_REAL_IP_FROM="$STABLE_CIDRS"
print_status "Internal ingress whitelist: $STABLE_CIDRS"

# =============================================================================
# One-time cleanup: Clear field manager conflicts from previous kubectl patches
# =============================================================================
# This block only runs ONCE when migrating from kubectl-managed to Helm-managed ingress.
# A marker annotation on the namespace tracks whether migration is complete.
# After migration, this entire block is skipped on future deploys.
# IMPORTANT: --show-managed-fields is required; kubectl doesn't include managedFields by default.
MIGRATION_MARKER=$(kubectl get namespace "$NS_INGRESS" -o jsonpath='{.metadata.annotations.mothertree\.io/ingress-helm-migration}' 2>/dev/null || echo "")
if [ "$MIGRATION_MARKER" = "complete" ]; then
  print_status "Ingress Helm migration already complete (marker found), skipping cleanup check"
else
  KUBECTL_CONFLICT_FOUND=""

  if kubectl get deployment ingress-nginx-controller -n "$NS_INGRESS" >/dev/null 2>&1; then
    DEPLOY_MANAGERS=$(kubectl get deployment ingress-nginx-controller -n "$NS_INGRESS" -o json --show-managed-fields 2>/dev/null | \
      jq -r '.metadata.managedFields[]?.manager // empty' | grep -E '^kubectl' || true)
    if [ -n "$DEPLOY_MANAGERS" ]; then
      echo "[DEBUG] Deployment has kubectl managers: $DEPLOY_MANAGERS"
      KUBECTL_CONFLICT_FOUND="deployment"
    fi
  fi

  if kubectl get service ingress-nginx-controller -n "$NS_INGRESS" >/dev/null 2>&1; then
    SVC_MANAGERS=$(kubectl get service ingress-nginx-controller -n "$NS_INGRESS" -o json --show-managed-fields 2>/dev/null | \
      jq -r '.metadata.managedFields[]?.manager // empty' | grep -E '^kubectl' || true)
    if [ -n "$SVC_MANAGERS" ]; then
      echo "[DEBUG] Service has kubectl managers: $SVC_MANAGERS"
      KUBECTL_CONFLICT_FOUND="${KUBECTL_CONFLICT_FOUND:+$KUBECTL_CONFLICT_FOUND,}service"
    fi
  fi

  if [ -n "$KUBECTL_CONFLICT_FOUND" ]; then
    print_warning "One-time cleanup: kubectl field managers detected on ingress-nginx ($KUBECTL_CONFLICT_FOUND)"
    print_status "Deleting ingress-nginx resources to allow clean Helm install (brief downtime)..."
    print_status "This only happens once - future deploys will be normal Helm upgrades."

    helm uninstall ingress-nginx -n "$NS_INGRESS" --wait 2>/dev/null || true

    kubectl delete deployment ingress-nginx-controller -n "$NS_INGRESS" --ignore-not-found=true --grace-period=0 --force 2>/dev/null || true
    kubectl delete service ingress-nginx-controller -n "$NS_INGRESS" --ignore-not-found=true 2>/dev/null || true
    kubectl delete service ingress-nginx-controller-admission -n "$NS_INGRESS" --ignore-not-found=true 2>/dev/null || true
    kubectl delete configmap tcp-services -n "$NS_INGRESS" --ignore-not-found=true 2>/dev/null || true
    kubectl delete configmap ingress-nginx-controller -n "$NS_INGRESS" --ignore-not-found=true 2>/dev/null || true

    print_status "Waiting for resources to be deleted..."
    for i in $(seq 1 30); do
      if ! kubectl get deployment ingress-nginx-controller -n "$NS_INGRESS" >/dev/null 2>&1 && \
         ! kubectl get service ingress-nginx-controller -n "$NS_INGRESS" >/dev/null 2>&1; then
        print_status "Cleanup complete, helmfile will reinstall ingress-nginx"
        break
      fi
      sleep 2
    done

    if kubectl get deployment ingress-nginx-controller -n "$NS_INGRESS" >/dev/null 2>&1 || \
       kubectl get service ingress-nginx-controller -n "$NS_INGRESS" >/dev/null 2>&1; then
      print_error "Failed to delete ingress-nginx resources. Manual cleanup required:"
      echo "  kubectl delete deployment ingress-nginx-controller -n $NS_INGRESS --force --grace-period=0"
      echo "  kubectl delete service ingress-nginx-controller -n $NS_INGRESS"
      exit 1
    fi
  else
    print_status "No field manager conflicts detected on ingress-nginx"
  fi

  print_status "Setting ingress Helm migration marker..."
  kubectl annotate namespace "$NS_INGRESS" "mothertree.io/ingress-helm-migration=complete" --overwrite
fi

# =============================================================================
# Cloud Firewall Controller - create API token secret
# =============================================================================
print_status "Setting up Cloud Firewall Controller API token..."
if [ -f "$REPO_ROOT/secrets.$MT_ENV.tfvars.env" ]; then
  source "$REPO_ROOT/secrets.$MT_ENV.tfvars.env"
fi
if [ -n "${TF_VAR_linode_token:-}" ]; then
  kubectl create secret generic linode-cfw -n kube-system \
    --from-literal=token="$TF_VAR_linode_token" \
    --dry-run=client -o yaml | kubectl apply -f -
  print_status "Cloud Firewall Controller secret created/updated in kube-system"
else
  print_warning "TF_VAR_linode_token not set - Cloud Firewall Controller will not have API access"
fi

# Migrate metrics-server from kubectl-managed to Helm-managed (one-time migration;
# on subsequent runs Helm already owns the resources and this block is skipped)
if kubectl get sa metrics-server -n kube-system &>/dev/null; then
  if ! kubectl get sa metrics-server -n kube-system -o jsonpath='{.metadata.labels.app\.kubernetes\.io/managed-by}' 2>/dev/null | grep -q "Helm"; then
    print_status "Migrating metrics-server from kubectl to Helm management..."
    kubectl delete deployment metrics-server -n kube-system --ignore-not-found=true
    kubectl delete service metrics-server -n kube-system --ignore-not-found=true
    kubectl delete serviceaccount metrics-server -n kube-system --ignore-not-found=true
    kubectl delete clusterrole system:metrics-server --ignore-not-found=true
    kubectl delete clusterrolebinding system:metrics-server --ignore-not-found=true
    kubectl delete clusterrolebinding metrics-server:system:auth-delegator --ignore-not-found=true
    kubectl delete rolebinding metrics-server-auth-reader -n kube-system --ignore-not-found=true
    kubectl delete apiservice v1beta1.metrics.k8s.io --ignore-not-found=true
    print_status "Old metrics-server resources removed, Helm will reinstall"
  fi
fi

# Apply persistent RBAC for cloud-firewall-controller (workaround for chart v0.2.0
# bug where RBAC resources are Helm hooks that get garbage-collected between upgrades)
print_status "Applying persistent cloud-firewall-controller RBAC..."
kubectl apply -f "$REPO_ROOT/apps/manifests/cloud-firewall-controller-rbac.yaml"

# =============================================================================
# Pre-sync: Migrate existing tcp-services entries to PROXY protocol format
# =============================================================================
# When PROXY protocol is enabled on the NodeBalancer, ALL TCP stream listeners
# must decode the PROXY header. This migration adds :PROXY: suffix to existing
# tcp-services entries BEFORE helmfile sync enables PROXY protocol on the NB,
# ensuring mail ports work correctly during the transition.
if kubectl get configmap tcp-services -n "$NS_INGRESS" >/dev/null 2>&1; then
  EXISTING_DATA=$(kubectl get configmap tcp-services -n "$NS_INGRESS" -o jsonpath='{.data}' 2>/dev/null || echo "{}")
  if [ -n "$EXISTING_DATA" ] && [ "$EXISTING_DATA" != "{}" ]; then
    print_status "Migrating tcp-services entries to PROXY protocol format..."
    kubectl get configmap tcp-services -n "$NS_INGRESS" -o json \
      | jq '.data |= with_entries(.value |= if test(":PROXY:$") then . else . + ":PROXY:" end)' \
      | kubectl apply -f -
    print_status "tcp-services entries migrated to PROXY protocol format"
  else
    print_status "tcp-services ConfigMap is empty, no migration needed"
  fi
else
  print_status "tcp-services ConfigMap does not exist yet, will be created by helmfile"
fi

# Deploy system components via helmfile
# Uses 'sync' instead of 'apply' to skip the slow diff operation —
# for large charts like kube-prometheus-stack, diff can take 10+ minutes.
print_status "Deploying system components (ingress, cert-manager, monitoring)..."
pushd "$REPO_ROOT/apps" >/dev/null
  max_retries=3
  retry_count=0
  HELMFILE_OUTPUT=""
  while [ $retry_count -lt $max_retries ]; do
    set +e
    HELMFILE_OUTPUT=$(helmfile -e "$MT_ENV" -l tier=system sync --skip-deps 2>&1)
    HELMFILE_EXIT=$?
    set -e

    echo "$HELMFILE_OUTPUT"

    if [ $HELMFILE_EXIT -eq 0 ]; then
      break
    fi

    # FAIL FAST: Check for field manager conflicts
    if echo "$HELMFILE_OUTPUT" | grep -q "conflicts with.*kubectl"; then
      echo ""
      print_error "Field manager conflict detected - this cannot be fixed by retrying."
      print_error "The ingress-nginx resources have kubectl-managed fields that conflict with Helm."
      echo ""
      echo "Manual fix required:"
      echo "  helm uninstall ingress-nginx -n $NS_INGRESS"
      echo "  kubectl delete deployment ingress-nginx-controller -n $NS_INGRESS --force --grace-period=0"
      echo "  kubectl delete service ingress-nginx-controller -n $NS_INGRESS"
      echo "  kubectl delete service ingress-nginx-controller-admission -n $NS_INGRESS"
      echo "  kubectl delete configmap tcp-services ingress-nginx-controller -n $NS_INGRESS"
      echo ""
      echo "Then re-run: ./scripts/deploy_infra -e $MT_ENV"
      exit 1
    fi

    retry_count=$((retry_count + 1))
    if [ $retry_count -lt $max_retries ]; then
      print_warning "helmfile sync failed (attempt $retry_count/$max_retries), retrying in 10 seconds..."
      sleep 10
    else
      print_error "helmfile sync failed after $max_retries attempts"
      exit 1
    fi
  done
popd >/dev/null

# Deploy matrix-alertmanager bridge (AlertManager -> Matrix room notifications)
if [ -n "${MATRIX_ALERTMANAGER_ACCESS_TOKEN:-}" ]; then
  print_status "Deploying alerting (matrix-alertmanager)..."
  if [ -f "$REPO_ROOT/apps/scripts/deploy-alerting.sh" ]; then
    if "$REPO_ROOT/apps/scripts/deploy-alerting.sh" -e "$MT_ENV" -t "$INFRA_TENANT_NAME"; then
      print_status "Alerting deployment complete"
    else
      print_warning "deploy-alerting.sh failed (non-fatal, continuing)"
    fi
  else
    print_warning "deploy-alerting.sh not found, skipping alerting deployment"
  fi
else
  print_warning "MATRIX_ALERTMANAGER_ACCESS_TOKEN not set — skipping matrix-alertmanager deployment"
  print_warning "Set alertbot.access_token in $INFRA_TENANT_NAME/${MT_ENV}.secrets.yaml and re-run"
fi

# Wait for ingress controller to get an external IP
print_status "Waiting for ingress controller LoadBalancer IP..."
INGRESS_IP=""
for i in $(seq 1 60); do
  INGRESS_IP=$(kubectl get service -n "$NS_INGRESS" ingress-nginx-controller -o jsonpath='{.status.loadBalancer.ingress[0].ip}' 2>/dev/null || echo "")
  if [ -n "$INGRESS_IP" ]; then
    print_status "Ingress controller LoadBalancer IP: $INGRESS_IP"
    break
  fi
  echo "Waiting for LoadBalancer IP... (attempt $i/60)"
  sleep 5
done

if [ -z "$INGRESS_IP" ]; then
  print_error "Ingress controller did not get an external IP after 5 minutes"
  exit 1
fi

# Deploy nginx ingress ServiceMonitor for metrics
print_status "Deploying nginx ingress ServiceMonitor..."
kubectl apply -f "$REPO_ROOT/apps/manifests/nginx-ingress-servicemonitor.yaml"

# =============================================================================
# Wait for monitoring stack
# =============================================================================
print_status "Checking monitoring stack readiness..."

PROM_READY=$(kubectl get pods -n "$NS_MONITORING" -l app.kubernetes.io/name=prometheus -o jsonpath='{.items[?(@.status.conditions[?(@.type=="Ready")].status=="True")].metadata.name}' 2>/dev/null || true)
if [ -n "$PROM_READY" ]; then
  print_status "Prometheus already ready: $PROM_READY"
else
  print_status "Waiting for Prometheus to be ready (max 3 min)..."
  kubectl wait --for=condition=ready pod -l app.kubernetes.io/name=prometheus -n "$NS_MONITORING" --timeout=180s 2>/dev/null || print_warning "Prometheus may not be fully ready yet"
fi

GRAFANA_READY=$(kubectl get pods -n "$NS_MONITORING" -l app.kubernetes.io/name=grafana -o jsonpath='{.items[?(@.status.conditions[?(@.type=="Ready")].status=="True")].metadata.name}' 2>/dev/null || true)
if [ -n "$GRAFANA_READY" ]; then
  print_status "Grafana already ready: $GRAFANA_READY"
else
  print_status "Waiting for Grafana to be ready (max 2 min)..."
  kubectl wait --for=condition=ready pod -l app.kubernetes.io/name=grafana -n "$NS_MONITORING" --timeout=120s 2>/dev/null || print_warning "Grafana may not be fully ready yet"
fi

# Deploy infrastructure endpoint probes
print_status "Deploying infrastructure endpoint probes..."
kubectl apply -f "$REPO_ROOT/apps/manifests/monitoring/infra-probes.yaml"

# Shared dashboards
print_status "Deploying shared Grafana dashboards..."
kubectl apply -f "$REPO_ROOT/apps/manifests/jitsi/jitsi-dashboard-configmap.yaml"
kubectl apply -f "$REPO_ROOT/apps/manifests/postgresql/postgresql-dashboard-configmap.yaml"
kubectl apply -f "$REPO_ROOT/apps/manifests/loki/loki-dashboard-configmap.yaml"

# =============================================================================
# Deploy Loki for centralized logging
# =============================================================================
print_status "Deploying Loki log aggregation..."
kubectl apply -f "$REPO_ROOT/apps/loki-manual.yaml"
kubectl apply -f "$REPO_ROOT/apps/manifests/loki/loki-servicemonitor.yaml"
kubectl apply -f "$REPO_ROOT/apps/manifests/loki/vector-servicemonitor.yaml"

LOKI_READY=$(kubectl get pods -n "$NS_MONITORING" -l app=loki -o jsonpath='{.items[?(@.status.conditions[?(@.type=="Ready")].status=="True")].metadata.name}' 2>/dev/null || true)
if [ -n "$LOKI_READY" ]; then
  print_status "Loki already ready: $LOKI_READY"
else
  print_status "Waiting for Loki to be ready (max 2 min)..."
  kubectl wait --for=condition=ready pod -l app=loki -n "$NS_MONITORING" --timeout=120s 2>/dev/null || print_warning "Loki may not be fully ready yet"
fi

# Wait for cert-manager to be ready
print_status "Waiting for cert-manager to be ready (parallel)..."
CERTMANAGER_PIDS=""
for d in cert-manager cert-manager-webhook cert-manager-cainjector; do
  if kubectl -n "$NS_CERTMANAGER" get deploy "$d" >/dev/null 2>&1; then
    kubectl -n "$NS_CERTMANAGER" rollout status deploy/"$d" --timeout=300s &
    CERTMANAGER_PIDS="$CERTMANAGER_PIDS $!"
  fi
done
for pid in $CERTMANAGER_PIDS; do
  wait $pid || print_warning "A cert-manager deployment rollout may not have completed"
done
print_status "Cert-manager is ready"

# =============================================================================
# Deploy ClusterIssuers and Cloudflare API token for cert-manager
# =============================================================================
print_status "Deploying ClusterIssuers and Cloudflare API token..."
export TLS_EMAIL="$TF_VAR_tls_email"
export CLOUDFLARE_API_TOKEN="$TF_VAR_cloudflare_api_token"
envsubst '${CLOUDFLARE_API_TOKEN} ${NS_CERTMANAGER}' < "$REPO_ROOT/apps/manifests/cert-manager/cloudflare-api-token.yaml.tpl" | kubectl apply -f -
envsubst '${TLS_EMAIL}' < "$REPO_ROOT/apps/manifests/cert-manager/clusterissuer-http01.yaml.tpl" | kubectl apply -f -
envsubst '${TLS_EMAIL}' < "$REPO_ROOT/apps/manifests/cert-manager/clusterissuer-dns01.yaml.tpl" | kubectl apply -f -
print_status "ClusterIssuers and Cloudflare API token deployed"

# Deploy PostgreSQL to shared database namespace
print_status "Deploying PostgreSQL to $NS_DB namespace..."

# SAFETY CHECK: Detect existing PostgreSQL PVC to prevent data loss
EXISTING_PVC=$(kubectl get pvc -n "$NS_DB" -l app.kubernetes.io/name=postgresql -o name 2>/dev/null | head -1 || echo "")
if [ -z "$EXISTING_PVC" ]; then
  RELEASED_PVS=$(kubectl get pv -o json 2>/dev/null | jq -r '.items[] | select(.status.phase=="Released") | select(.spec.claimRef.namespace=="'"$NS_DB"'") | select(.spec.claimRef.name | startswith("data-docs-postgresql")) | .metadata.name' || echo "")
  if [ -n "$RELEASED_PVS" ]; then
    print_error "No PostgreSQL PVC found in $NS_DB but Released PVs exist with postgres data!"
    print_error "Released PVs: $RELEASED_PVS"
    print_error "This may indicate a namespace issue that would cause DATA LOSS."
    print_error "Set ALLOW_NEW_PVC=true to proceed (data will NOT be migrated)"
    if [ "${ALLOW_NEW_PVC:-}" != "true" ]; then
      exit 1
    fi
    print_warning "ALLOW_NEW_PVC=true set - proceeding with new PVC"
  else
    print_status "No existing PostgreSQL PVC - this appears to be a fresh install"
  fi
else
  print_status "Existing PostgreSQL PVC found: $EXISTING_PVC"
fi

# Check for existing PostgreSQL secret and add replication-password if missing
if kubectl get secret docs-postgresql -n "$NS_DB" &>/dev/null; then
  if ! kubectl get secret docs-postgresql -n "$NS_DB" -o jsonpath='{.data.replication-password}' 2>/dev/null | grep -q .; then
    print_status "PostgreSQL: patching existing secret to add replication-password"
    REPL_PASSWORD=$(openssl rand -base64 18)
    kubectl patch secret docs-postgresql -n "$NS_DB" --type='json' \
      -p="[{\"op\": \"add\", \"path\": \"/data/replication-password\", \"value\": \"$(echo -n "$REPL_PASSWORD" | base64)\"}]"
  fi
fi

# Deploy with replication enabled
PG_READ_REPLICAS="${PG_READ_REPLICAS:-1}"
PG_ENV_VALUES=""
if [ -f "$REPO_ROOT/apps/environments/${MT_ENV}/docs-postgresql.yaml" ]; then
  PG_ENV_VALUES="--values $REPO_ROOT/apps/environments/${MT_ENV}/docs-postgresql.yaml"
fi

helm upgrade --install docs-postgresql oci://registry-1.docker.io/bitnamicharts/postgresql \
  --version 18.2.3 \
  --namespace "$NS_DB" \
  --values "$REPO_ROOT/apps/values/docs-postgresql.yaml" \
  $PG_ENV_VALUES \
  --set "architecture=replication" \
  --set "readReplicas.replicaCount=${PG_READ_REPLICAS}" \
  --set "global.security.allowInsecureImages=true" \
  --wait \
  --timeout 600s

print_status "Waiting for PostgreSQL to be ready..."
kubectl wait --for=condition=ready pod -l app.kubernetes.io/name=postgresql -n "$NS_DB" --timeout=300s

# Create Keycloak theme ConfigMap BEFORE deploying Keycloak
print_status "Creating Keycloak theme ConfigMap..."
THEMES_DIR="$REPO_ROOT/apps/themes"
if [ -d "$THEMES_DIR/platform" ]; then
  print_status "Packaging platform theme..."
  TMP_TAR=$(mktemp /tmp/platform-theme-XXXXXX.tar.gz)
  pushd "$THEMES_DIR" >/dev/null
    tar -czf "$TMP_TAR" platform
  popd >/dev/null

  kubectl -n "$NS_AUTH" create configmap keycloak-platform-theme \
      --from-file=theme.tar.gz="$TMP_TAR" \
      --dry-run=client -o yaml | kubectl apply -f -
  rm -f "$TMP_TAR"
  print_status "Platform theme ConfigMap created in namespace $NS_AUTH"
else
  print_warning "Theme directory not found at $THEMES_DIR/platform, skipping theme ConfigMap"
fi

# Detect PostgreSQL service hostname from cluster state
if kubectl get service docs-postgresql-primary -n "$NS_DB" >/dev/null 2>&1; then
  export PG_SERVICE_NAME="docs-postgresql-primary"
  print_status "PostgreSQL: detected replication mode (docs-postgresql-primary)"
else
  export PG_SERVICE_NAME="docs-postgresql"
  print_status "PostgreSQL: detected standalone mode (docs-postgresql)"
fi
export PG_HOST="${PG_SERVICE_NAME}.${NS_DB}.svc.cluster.local"

# Verify shared infra secrets were loaded by infra-config.sh
# (KEYCLOAK_ADMIN_PASSWORD, KEYCLOAK_DB_PASSWORD, TF_VAR_grafana_admin_password)
if [ -z "${KEYCLOAK_ADMIN_PASSWORD:-}" ] || [ "${KEYCLOAK_ADMIN_PASSWORD}" = "null" ] || \
   [ -z "${KEYCLOAK_DB_PASSWORD:-}" ] || [ "${KEYCLOAK_DB_PASSWORD}" = "null" ]; then
  print_error "Keycloak admin/DB passwords not loaded by infra-config.sh"
  print_error "Add keycloak.admin_password and keycloak.db_password to tenants/$INFRA_TENANT_NAME/${MT_ENV}.secrets.yaml"
  exit 1
fi

# Sync Keycloak DB password in PostgreSQL to match secrets file.
# The password may have been set to a different value during initial DB creation,
# so we always ensure it matches the current secrets file value.
# Note: sed escapes single quotes in the password to prevent SQL injection.
print_status "Syncing Keycloak DB password in PostgreSQL..."
PG_SUPERUSER_PASS=$(kubectl get secret docs-postgresql -n "$NS_DB" --kubeconfig="$REPO_ROOT/kubeconfig.$MT_ENV.yaml" -o jsonpath='{.data.postgres-password}' | base64 -d)
kubectl exec -i "${PG_SERVICE_NAME}-0" -n "$NS_DB" --kubeconfig="$REPO_ROOT/kubeconfig.$MT_ENV.yaml" -- \
  env PGPASSWORD="$PG_SUPERUSER_PASS" psql -U postgres -c "ALTER ROLE keycloak WITH PASSWORD '$(echo "$KEYCLOAK_DB_PASSWORD" | sed "s/'/''/g")';" 2>/dev/null || \
  print_warning "Could not update keycloak DB password — PostgreSQL may not be ready yet"

# Deploy Keycloak (needs PostgreSQL)
print_status "Deploying Keycloak to $NS_AUTH namespace (replicas: $KEYCLOAK_REPLICAS)..."
pushd "$REPO_ROOT/apps" >/dev/null
  helmfile -e "$MT_ENV" -l name=keycloak sync --skip-deps
popd >/dev/null

# Restart Keycloak to pick up any theme ConfigMap changes.
# The init container extracts the theme tar.gz on startup, so a restart is needed
# when theme files change. This is safe — Keycloak handles graceful shutdown.
print_status "Restarting Keycloak to pick up theme changes..."
kubectl -n "$NS_AUTH" rollout restart statefulset/keycloak-keycloakx
kubectl -n "$NS_AUTH" rollout status statefulset/keycloak-keycloakx --timeout=300s

# Sync Keycloak admin password.
# The KEYCLOAK_ADMIN_PASSWORD env var only applies on first boot; afterwards the
# password is stored in Keycloak's database. We use kcadm.sh to verify/update it,
# handling credential rotation and migration from legacy hardcoded passwords.
print_status "Waiting for Keycloak to be ready before syncing admin password..."
kubectl wait --for=condition=ready pod/keycloak-keycloakx-0 -n "$NS_AUTH" \
  --kubeconfig="$REPO_ROOT/kubeconfig.$MT_ENV.yaml" --timeout=180s 2>/dev/null || true

print_status "Syncing Keycloak admin password..."
if kubectl exec keycloak-keycloakx-0 -n "$NS_AUTH" -c keycloak \
    --kubeconfig="$REPO_ROOT/kubeconfig.$MT_ENV.yaml" -- \
    /opt/keycloak/bin/kcadm.sh config credentials \
    --server http://localhost:8080 --realm master \
    --user admin --password "$KEYCLOAK_ADMIN_PASSWORD" 2>/dev/null; then
  print_status "Keycloak admin password already matches secrets file"
else
  LEGACY_PASSWORDS=("keycloak-admin-password-change-me" "admin" "changeme")
  ADMIN_UPDATED=false
  for old_pass in "${LEGACY_PASSWORDS[@]}"; do
    if kubectl exec keycloak-keycloakx-0 -n "$NS_AUTH" -c keycloak \
        --kubeconfig="$REPO_ROOT/kubeconfig.$MT_ENV.yaml" -- \
        /opt/keycloak/bin/kcadm.sh config credentials \
        --server http://localhost:8080 --realm master \
        --user admin --password "$old_pass" 2>/dev/null; then
      print_status "Authenticated with legacy password, updating to new password..."
      kubectl exec keycloak-keycloakx-0 -n "$NS_AUTH" -c keycloak \
          --kubeconfig="$REPO_ROOT/kubeconfig.$MT_ENV.yaml" -- \
          /opt/keycloak/bin/kcadm.sh set-password \
          --server http://localhost:8080 --realm master \
          --username admin --new-password "$KEYCLOAK_ADMIN_PASSWORD" 2>/dev/null && \
        print_status "Keycloak admin password updated successfully" && ADMIN_UPDATED=true
      break
    fi
  done
  if [ "$ADMIN_UPDATED" != "true" ]; then
    print_warning "Could not sync Keycloak admin password — manual reset may be needed"
  fi
fi

# NOTE: DNS records are now managed by manage_infra --dns (via scripts/manage-dns.sh)
# NOTE: LKE firewall rules are now managed by manage_infra --firewall. See issue #244.

# =============================================================================
# Deploy K8s Postfix (ConfigMaps, Deployment, Services, NetworkPolicy)
# =============================================================================
print_status "Deploying K8s Postfix..."
if [ -x "$REPO_ROOT/apps/deploy-postfix.sh" ]; then
  "$REPO_ROOT/apps/deploy-postfix.sh" -e "$MT_ENV" --nesting-level=$((MT_NESTING_LEVEL+1)) 2>&1 | sed 's/^/  /'
else
  print_error "deploy-postfix.sh not found"
  exit 1
fi

# =============================================================================
# Configure K8s Postfix mail routing using shared script
# =============================================================================
print_status "Configuring K8s Postfix mail routing..."
if [ -x "$REPO_ROOT/scripts/configure-mail-routing" ]; then
  "$REPO_ROOT/scripts/configure-mail-routing" -e "$MT_ENV" --nesting-level=$((MT_NESTING_LEVEL+1)) 2>&1 | sed 's/^/  /'
else
  print_warning "configure-mail-routing script not found"
fi

# =============================================================================
# Configure nginx TCP proxy for inbound SMTP (port 30025 -> Postfix:25)
# =============================================================================
# Routes VPN Postfix inbound mail through the ingress-nginx NodeBalancer TCP proxy.
# The NodeBalancer has a stable IP (lb1.<env>.<domain>) and its subnet is permanently
# allowed through the LKE firewall. This avoids reliance on hardcoded K8s node VPC IPs.
# Two things are needed:
#   1. tcp-services ConfigMap entries (tells nginx where to proxy)
#   2. LB service ports (tells the cloud LB to forward to nginx's NodePort)
print_status "Configuring nginx TCP proxy for Postfix inbound SMTP..."

if ! kubectl get configmap tcp-services -n "$NS_INGRESS" >/dev/null 2>&1; then
  print_status "Creating tcp-services ConfigMap..."
  kubectl create configmap tcp-services -n "$NS_INGRESS"
fi

kubectl patch configmap tcp-services -n "$NS_INGRESS" --type merge -p '{"data": {"30025": "infra-mail/postfix:25:PROXY:"}}'
print_status "tcp-services ConfigMap updated with 30025 -> infra-mail/postfix:25:PROXY:"

EXISTING_PORTS=$(kubectl get svc ingress-nginx-controller -n "$NS_INGRESS" -o jsonpath='{.spec.ports[*].port}' 2>/dev/null || echo "")
if ! echo "$EXISTING_PORTS" | grep -qw "30025"; then
  print_status "Adding port 30025 (smtp-inbound) to ingress-nginx LB service..."
  kubectl patch svc ingress-nginx-controller -n "$NS_INGRESS" --type='json' \
    -p='[{"op": "add", "path": "/spec/ports/-", "value": {"name": "smtp-inbound", "port": 30025, "targetPort": 30025, "protocol": "TCP"}}]'
else
  print_status "Port 30025 already present on ingress-nginx LB service"
fi

# =============================================================================
# Deploy VPN Route DaemonSet
# =============================================================================
if [ -n "$VPN_SERVER_PRIVATE_IP" ]; then
  print_status "Deploying VPN route DaemonSet for VPN server: $VPN_SERVER_PRIVATE_IP"

  sed "s|\${VPN_SERVER_PRIVATE_IP}|$VPN_SERVER_PRIVATE_IP|g" \
    "$REPO_ROOT/apps/manifests/vpn-route-daemonset.yaml.tpl" | kubectl apply -f -

  print_status "VPN route DaemonSet deployed - pods can now reach $VPN_SERVER_PRIVATE_IP"
else
  print_warning "VPN server private IP not found in Terraform outputs, skipping route DaemonSet"
fi

# NOTE: Ansible (VPN Postfix, TURN, Unbound) is now managed by manage_infra --ansible. See issue #244.

# Wait for linkeditor build that was started in background at the beginning
if [ -n "$LINKEDITOR_BUILD_PID" ]; then
  print_status "Waiting for files_linkeditor build to complete..."
  if wait $LINKEDITOR_BUILD_PID; then
    print_success "files_linkeditor app built"
  else
    print_warning "files_linkeditor build may have failed. Check /tmp/linkeditor-build.log"
    cat /tmp/linkeditor-build.log 2>/dev/null | tail -20 || true
  fi
elif [ -d "$REPO_ROOT/submodules/files_linkeditor" ]; then
  if [ -f "$REPO_ROOT/scripts/build-linkeditor.sh" ]; then
    print_status "Building files_linkeditor Nextcloud app..."
    "$REPO_ROOT/scripts/build-linkeditor.sh" --nesting-level=$((MT_NESTING_LEVEL+1))
    print_success "files_linkeditor app built"
  else
    print_warning "build-linkeditor.sh not found, skipping files_linkeditor build"
  fi
else
  print_status "files_linkeditor submodule not found, skipping (optional component)"
fi

# Run post-deploy health check (non-blocking)
echo ""
print_status "Running post-deploy health check..."
"$REPO_ROOT/scripts/check-health" -e "$MT_ENV" || print_warning "Issues detected - review above"

echo ""
print_success "Shared infrastructure deployed for $MT_ENV!"
echo ""
echo "Infrastructure namespaces:"
echo "  - $NS_DB (PostgreSQL)"
echo "  - $NS_AUTH (Keycloak)"
echo "  - $NS_MONITORING (Prometheus, Grafana)"
echo "  - $NS_INGRESS (Public ingress)"
echo "  - $NS_INGRESS_INTERNAL (VPN-only ingress)"
echo "  - $NS_CERTMANAGER (Cert-manager)"
echo "  - $NS_MAIL (Postfix SMTP)"
echo ""
echo "Next steps:"
echo "  Deploy tenants with: ./scripts/create_env -e $MT_ENV -t <tenant>"
