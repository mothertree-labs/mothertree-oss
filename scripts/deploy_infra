# =============================================================================
if [ -x "$REPO_ROOT/apps/deploy-llm.sh" ]; then
  print_status "Deploying Ollama inference engine..."
  "$REPO_ROOT/apps/deploy-llm.sh" -e "$MT_ENV" --nesting-level=$((MT_NESTING_LEVEL+1)) 2>&1 | sed 's/^/  /' || \
    print_warning "Ollama deploy incomplete — model may still be pulling on a cold-start node"
else
  print_warning "deploy-llm.sh not found, skipping Ollama deployment"
fi

# Deploy Tailscale subnet router for operator access to internal services.
# Provides split DNS + subnet routing so operators can reach Grafana, Prometheus, etc.
# Non-blocking — router failure shouldn't fail the deploy.
if [ -x "$REPO_ROOT/apps/deploy-tailscale-router.sh" ]; then
  print_status "Deploying Tailscale subnet router..."
  "$REPO_ROOT/apps/deploy-tailscale-router.sh" -e "$MT_ENV" --nesting-level=$((MT_NESTING_LEVEL+1)) 2>&1 | sed 's/^/  /' || \
    print_warning "Tailscale router deploy failed (non-fatal)"
fi

# Run post-deploy health check (non-blocking)
echo ""
print_status "Running post-deploy health check..."
"$REPO_ROOT/scripts/check-health" -e "$MT_ENV" || print_warning "Issues detected - review above"

echo ""
print_success "Shared infrastructure deployed for $MT_ENV!"
echo ""
echo "Infrastructure namespaces:"
echo "  - $NS_DB (PgBouncer → external PG VM)"
echo "  - $NS_AUTH (Keycloak)"
echo "  - $NS_MONITORING (Prometheus, Grafana)"
echo "  - $NS_INGRESS (Public ingress)"
echo "  - $NS_INGRESS_INTERNAL (Internal ingress)"
echo "  - $NS_CERTMANAGER (Cert-manager)"
echo "  - $NS_MAIL (Postfix SMTP)"
echo "  - $NS_LLM (Ollama)"
echo ""
echo "Next steps:"
echo "  Deploy tenants with: ./scripts/create_env -e $MT_ENV -t <tenant>"
