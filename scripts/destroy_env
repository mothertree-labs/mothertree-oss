#!/bin/bash

# Destroy Environment
# Purpose: Tear down all resources for an environment
#
# Usage:
#   ./scripts/destroy_env -e <env>
#   ./scripts/destroy_env <env>    (backward compat)

set -euo pipefail

REPO_ROOT="${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "${REPO_ROOT}/scripts/lib/common.sh"
source "${REPO_ROOT}/scripts/lib/args.sh"

mt_usage() {
  echo "Usage: $0 -e <env>"
  echo ""
  echo "Destroy all resources for an environment."
  echo ""
  echo "Options:"
  echo "  -e <env>    Environment (e.g., dev, prod)"
  echo "  -h, --help  Show this help"
}

mt_parse_args "$@"
mt_require_env

print_status "Destroying environment: $MT_ENV"

# Load secrets for terraform providers - prefer env-specific for completeness
if [ -f "$REPO_ROOT/secrets.${MT_ENV}.tfvars.env" ]; then
  # shellcheck disable=SC1091
  source "$REPO_ROOT/secrets.${MT_ENV}.tfvars.env"
  print_status "Loaded secrets from secrets.${MT_ENV}.tfvars.env"
else
  print_warning "No env-specific secrets file found at $REPO_ROOT/secrets.${MT_ENV}.tfvars.env; continuing (destroy may still work if providers are configured)"
fi

# Docs cleanup (render + delete)
export KUBECONFIG="$REPO_ROOT/kubeconfig.$MT_ENV.yaml"
# Note: Environment variables (DOCS_HOST, AUTH_HOST, etc.) should be set
# by the calling script (create_env) from tenant config, or export them manually
if [ -f "$REPO_ROOT/docs/docs-config.yaml.tpl" ]; then
  print_status "Deleting Docs manifests"
  envsubst < "$REPO_ROOT/docs/ingress.yaml.tpl" | kubectl delete -f - --ignore-not-found=true || true
  envsubst < "$REPO_ROOT/docs/docs-config.yaml.tpl" | kubectl delete -f - --ignore-not-found=true || true
fi
kubectl delete -f "$REPO_ROOT/docs/backend-deployment.yaml" --ignore-not-found=true || true
kubectl delete -f "$REPO_ROOT/docs/backend-service.yaml" --ignore-not-found=true || true
kubectl delete -f "$REPO_ROOT/docs/y-provider-deployment.yaml" --ignore-not-found=true || true
kubectl delete -f "$REPO_ROOT/docs/y-provider-service.yaml" --ignore-not-found=true || true
kubectl delete -f "$REPO_ROOT/docs/db-init-job.yaml" --ignore-not-found=true || true

# Apps teardown
pushd "$REPO_ROOT/apps" >/dev/null
  helmfile -e "$MT_ENV" destroy || true
popd >/dev/null

# Infra teardown
pushd "$REPO_ROOT/infra" >/dev/null
  terraform init -input=false
  if terraform workspace select "$MT_ENV" 2>/dev/null; then
    print_status "Destroying infra resources in workspace: $MT_ENV"
    # For prod, use empty env_dns_label to match create_env behavior
    if [ "$MT_ENV" = "prod" ]; then
      terraform destroy -input=false -auto-approve -var env="$MT_ENV" -var env_dns_label=""
    else
      terraform destroy -input=false -auto-approve -var env="$MT_ENV" -var env_dns_label="$MT_ENV"
    fi
  else
    print_warning "Workspace '$MT_ENV' does not exist in infra, skipping infra teardown"
  fi
popd >/dev/null

# Phase1 teardown
pushd "$REPO_ROOT/phase1" >/dev/null
  terraform init -input=false
  if terraform workspace select "$MT_ENV" 2>/dev/null; then
    print_status "Destroying phase1 resources in workspace: $MT_ENV"
    # For prod, use empty env_dns_label to match create_env behavior
    if [ "$MT_ENV" = "prod" ]; then
      terraform destroy -input=false -auto-approve -var env="$MT_ENV" -var env_dns_label=""
    else
      terraform destroy -input=false -auto-approve -var env="$MT_ENV" -var env_dns_label="$MT_ENV"
    fi
  else
    print_warning "Workspace '$MT_ENV' does not exist in phase1, skipping phase1 teardown"
  fi
popd >/dev/null

print_success "Environment '$MT_ENV' destroyed."
