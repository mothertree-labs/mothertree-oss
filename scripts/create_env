FONTS_DIR="$REPO_ROOT/apps/account-portal/public/fonts"
ASSETS_DIR="$REPO_ROOT/apps/account-portal/public"
kubectl -n "$NS_MATRIX" create configmap element-branding \
    --from-file=favicon.svg="$ASSETS_DIR/favicon.svg" \
