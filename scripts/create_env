#!/bin/bash

# Tenant Environment Deployment Script
# Purpose: Deploy tenant applications (CI-ready)
#
# Prerequisites:
#   - Cluster must exist (run manage_infra first)
#   - Shared infrastructure must be deployed (run deploy_infra first)
#   - Kubeconfig must be available
#   - Tenant config and secrets must exist
#
# Usage:
#   ./scripts/create_env -e <env> -t <tenant> [options]
#   ./scripts/create_env --tenant=<name> <env> [options]   (backward compat)
#
# Examples:
#   ./scripts/create_env -e prod -t example
#   ./scripts/create_env -e dev -t example --create-alert-user

set -euo pipefail

REPO_ROOT="${REPO_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "${REPO_ROOT}/scripts/lib/common.sh"
source "${REPO_ROOT}/scripts/lib/args.sh"

mt_usage() {
  echo "Usage: $0 -e <env> -t <tenant> [options]"
  echo ""
  echo "Deploy all tenant applications."
  echo ""
  echo "Options:"
  echo "  -e <env>              Environment (e.g., dev, prod)"
  echo "  -t <tenant>           Tenant name (e.g., example)"
  echo "  --create-alert-user   Create the alertbot Matrix user for alerting"
  echo "  --prep-only           Run only Phase 1 (namespaces, TLS, DNS, Keycloak realm)"
  echo "  --finalize-only       Run only the finalize phase (cleanup, probes, health checks)"
  echo "  -h, --help            Show this help"
  echo ""
  echo "Examples:"
  echo "  $0 -e prod -t example"
  echo "  $0 -e dev -t example --create-alert-user"
  echo "  $0 -e dev -t example --prep-only     # CI: run before parallel app deploys"
  echo "  $0 -e dev -t example --finalize-only  # CI: run after parallel app deploys"
}

mt_parse_args "$@"
mt_require_env
mt_require_tenant

# Source project config if available (provides CONTAINER_REGISTRY, GITHUB_ORG)
source "${REPO_ROOT}/scripts/lib/paths.sh"
_mt_resolve_project_conf
[[ -n "$MT_PROJECT_CONF" ]] && source "$MT_PROJECT_CONF"

# Load all tenant configuration and secrets
source "${REPO_ROOT}/scripts/lib/config.sh"
mt_load_tenant_config

# Check flags
CREATE_ALERT_USER="false"
if mt_has_flag "--create-alert-user"; then
  CREATE_ALERT_USER="true"
fi

PREP_ONLY="false"
if mt_has_flag "--prep-only"; then
  PREP_ONLY="true"
fi

FINALIZE_ONLY="false"
if mt_has_flag "--finalize-only"; then
  FINALIZE_ONLY="true"
fi

if [ "$PREP_ONLY" = "true" ] && [ "$FINALIZE_ONLY" = "true" ]; then
  print_error "Cannot use both --prep-only and --finalize-only"
  exit 1
fi

source "${REPO_ROOT}/scripts/lib/notify.sh"
mt_deploy_start "create_env"

mt_require_commands kubectl helm helmfile envsubst yq openssl jq curl

print_status "Deploying tenant: $TENANT_NAME"
print_status "Environment: $MT_ENV"
print_status "Config: $TENANT_CONFIG"
if [ "$CREATE_ALERT_USER" = "true" ]; then
  print_status "Alertbot Matrix user will be created"
fi

print_status "Tenant domain: $TENANT_DOMAIN"
print_status "DNS label: ${TENANT_ENV_DNS_LABEL:-"(none - prod)"}"
print_status "Namespace prefix: $TENANT_NS_PREFIX"
print_status "Email domain: $EMAIL_DOMAIN (for SPF/DKIM/DMARC records)"
print_status "Hosts: matrix=$MATRIX_HOST, docs=$DOCS_HOST, files=$FILES_HOST, jitsi=$JITSI_HOST"
print_status "Hosts: mail=$MAIL_HOST, webmail=$WEBMAIL_HOST, admin=$ADMIN_HOST, calendar=$CALENDAR_HOST, office=$OFFICE_HOST"
print_status "S3 bucket (files): $S3_FILES_BUCKET"
print_status "Scaling: docs_backend=$DOCS_BACKEND_MIN_REPLICAS-$DOCS_BACKEND_MAX_REPLICAS, jvb=$JVB_MIN_REPLICAS-$JVB_MAX_REPLICAS, redis=$REDIS_REPLICAS"

# When --finalize-only, skip infra verification and helm setup (already done in prep)
if [ "$FINALIZE_ONLY" = "true" ]; then
  print_status "Running finalize-only mode — skipping to cleanup and health checks"
  # Jump past all prep and app deploy sections to the finalize block
  # (the FINALIZE_ONLY != true guard below will skip app deploys)
else

# Verify infrastructure is deployed
print_status "Verifying shared infrastructure is deployed..."
if ! kubectl get namespace "$NS_DB" >/dev/null 2>&1; then
  print_error "Infrastructure namespace $NS_DB not found."
  echo ""
  echo "Shared infrastructure must be deployed before deploying tenants."
  echo "Run './scripts/deploy_infra $MT_ENV' first."
  exit 1
fi

if ! kubectl get deployment -n "$NS_INGRESS" ingress-nginx-controller >/dev/null 2>&1; then
  print_error "Ingress controller not found in $NS_INGRESS namespace."
  echo ""
  echo "Shared infrastructure must be deployed before deploying tenants."
  echo "Run './scripts/deploy_infra $MT_ENV' first."
  exit 1
fi

print_status "Infrastructure verified"

export HELM_DIFF_USE_HELM_TEMPLATE=true

# =============================================================================
# Consolidate helm repo updates (done once here, skipped in sub-scripts)
# =============================================================================
print_status "Updating helm repositories (consolidated)..."
helm repo add bitnami https://charts.bitnami.com/bitnami 2>/dev/null || true
helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx 2>/dev/null || true
helm repo add jetstack https://charts.jetstack.io 2>/dev/null || true
helm repo add ananace https://ananace.gitlab.io/charts/ 2>/dev/null || true
helm repo add halkeye https://halkeye.github.io/helm-charts 2>/dev/null || true
helm repo add prometheus-community https://prometheus-community.github.io/helm-charts 2>/dev/null || true
helm repo add vector https://helm.vector.dev 2>/dev/null || true
helm repo add nextcloud https://nextcloud.github.io/helm/ 2>/dev/null || true
helm repo add codecentric https://codecentric.github.io/helm-charts 2>/dev/null || true
helm repo add metrics-server https://kubernetes-sigs.github.io/metrics-server/ 2>/dev/null || true
helm repo add emberstack https://emberstack.github.io/helm-charts 2>/dev/null || true
helm repo add collabora https://collaboraonline.github.io/online/ 2>/dev/null || true
helm repo update >/dev/null 2>&1 &
HELM_REPO_UPDATE_PID=$!
print_status "Helm repo update started in background (PID: $HELM_REPO_UPDATE_PID)"

# Create tenant namespaces (tn-<tenant>-*)
print_status "Creating tenant namespaces..."
kubectl create namespace "$NS_MATRIX" 2>/dev/null || true
kubectl create namespace "$NS_DOCS" 2>/dev/null || true
kubectl create namespace "$NS_FILES" 2>/dev/null || true
kubectl create namespace "$NS_JITSI" 2>/dev/null || true
kubectl create namespace "$NS_STALWART" 2>/dev/null || true
kubectl create namespace "$NS_WEBMAIL" 2>/dev/null || true
kubectl create namespace "$NS_ADMIN" 2>/dev/null || true
if [ "$OFFICE_ENABLED" = "true" ]; then
  kubectl create namespace "$NS_OFFICE" 2>/dev/null || true
fi
print_status "Tenant namespaces created/verified"

# =============================================================================
# Deploy per-tenant wildcard TLS certificate (DNS-01 via Cloudflare)
# =============================================================================
# A single wildcard cert covers all tenant subdomains (external + internal).
# Reflector mirrors the resulting secret to every tenant namespace.
print_status "Deploying wildcard TLS certificate for $TENANT_NAME..."

# Compute wildcard domains based on environment
if [ -n "$TENANT_ENV_DNS_LABEL" ] && [ "$TENANT_ENV_DNS_LABEL" != "null" ]; then
  # Dev: *.dev.example.com + *.internal.dev.example.com + dev.example.com
  export WILDCARD_DOMAIN_EXTERNAL="*.${TENANT_ENV_DNS_LABEL}.${TENANT_DOMAIN}"
  export WILDCARD_DOMAIN_INTERNAL="*.internal.${TENANT_ENV_DNS_LABEL}.${TENANT_DOMAIN}"
  export WILDCARD_DOMAIN_BARE="${TENANT_ENV_DNS_LABEL}.${TENANT_DOMAIN}"
else
  # Prod: *.example.com + *.prod.example.com + example.com
  export WILDCARD_DOMAIN_EXTERNAL="*.${TENANT_DOMAIN}"
  export WILDCARD_DOMAIN_INTERNAL="*.prod.${TENANT_DOMAIN}"
  export WILDCARD_DOMAIN_BARE="${TENANT_DOMAIN}"
fi

# Build comma-separated list of namespaces for reflector (all tenant ns except NS_MATRIX, plus infra-auth)
export TENANT_NAMESPACES="${NS_STALWART},${NS_DOCS},${NS_FILES},${NS_JITSI},${NS_WEBMAIL},${NS_ADMIN},${NS_AUTH}"
if [ "$OFFICE_ENABLED" = "true" ]; then
  export TENANT_NAMESPACES="${TENANT_NAMESPACES},${NS_OFFICE}"
fi

# Export Cloudflare token and TLS email for the certificate template
export CLOUDFLARE_API_TOKEN="$TF_VAR_cloudflare_api_token"
export TLS_EMAIL="$TF_VAR_tls_email"

print_status "Wildcard domains: external=$WILDCARD_DOMAIN_EXTERNAL, internal=$WILDCARD_DOMAIN_INTERNAL"
print_status "Reflector target namespaces: $TENANT_NAMESPACES"

envsubst < "$REPO_ROOT/apps/manifests/wildcard/certificate.yaml.tpl" | kubectl apply -f -
print_status "Wildcard certificate resources applied"

# Wait for the certificate to be issued (DNS-01 can take 1-2 minutes)
# cert-manager's Cloudflare DNS solver has a known issue where challenge cleanup
# fails with an empty zone ID, causing a deadlock: validated challenges can't
# finalize, blocking remaining challenges from starting. We detect this and
# recover by removing finalizers from stuck challenges and letting cert-manager retry.
print_status "Waiting for wildcard certificate to be ready (DNS-01 validation)..."
if kubectl wait --for=condition=Ready certificate/wildcard-tls -n "$NS_MATRIX" --timeout=120s 2>/dev/null; then
  print_success "Wildcard TLS certificate is ready"
else
  print_warning "Certificate not ready after 120s, checking for stuck challenges..."

  # Find challenges stuck in cleanup (valid state but finalizer prevents GC)
  STUCK_CHALLENGES=$(kubectl get challenges -n "$NS_MATRIX" -o json 2>/dev/null \
    | jq -r '.items[]
             | select(.metadata.name | startswith("wildcard-tls-"))
             | select(.status.state == "valid")
             | select((.metadata.finalizers // []) | length > 0)
             | .metadata.name' 2>/dev/null)

  if [ -n "$STUCK_CHALLENGES" ]; then
    print_status "Found challenges stuck in cleanup — removing finalizers to allow retry..."
    for ch in $STUCK_CHALLENGES; do
      kubectl patch challenge "$ch" -n "$NS_MATRIX" \
        --type=json -p='[{"op":"remove","path":"/metadata/finalizers"}]' 2>/dev/null \
        && print_status "  Removed finalizer from $ch"
    done

    # Delete remaining wildcard challenges (e.g. ones that never started)
    kubectl get challenges -n "$NS_MATRIX" -o name 2>/dev/null \
      | grep "wildcard-tls-" \
      | xargs -r kubectl delete -n "$NS_MATRIX" 2>/dev/null || true

    # Delete stale orders and certificate requests so cert-manager retries from scratch
    kubectl get orders -n "$NS_MATRIX" -o name 2>/dev/null \
      | grep "wildcard-tls-" \
      | xargs -r kubectl delete -n "$NS_MATRIX" 2>/dev/null || true
    kubectl get certificaterequests -n "$NS_MATRIX" -o name 2>/dev/null \
      | grep "wildcard-tls-" \
      | xargs -r kubectl delete -n "$NS_MATRIX" 2>/dev/null || true

    print_status "Waiting for cert-manager to retry (up to 180s)..."
    if kubectl wait --for=condition=Ready certificate/wildcard-tls -n "$NS_MATRIX" --timeout=180s 2>/dev/null; then
      print_success "Wildcard TLS certificate is ready (after retry)"
    else
      print_warning "Wildcard certificate still not ready after retry"
      print_warning "Check status: kubectl get certificate wildcard-tls -n $NS_MATRIX"
      print_warning "Continuing deployment — ingresses will use the cert once it's issued"
    fi
  else
    print_warning "No stuck challenges found — certificate may still be validating"
    print_warning "Check status: kubectl get certificate wildcard-tls -n $NS_MATRIX"
    print_warning "Continuing deployment — ingresses will use the cert once it's issued"
  fi
fi

# =============================================================================
# Deploy NetworkPolicies for tenant isolation
# =============================================================================
print_status "Deploying NetworkPolicies for tenant isolation..."
if [ -x "$REPO_ROOT/apps/deploy-network-policies.sh" ]; then
  if "$REPO_ROOT/apps/deploy-network-policies.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)); then
    print_status "NetworkPolicies deployed successfully"
  else
    print_warning "NetworkPolicy deployment had issues (non-fatal, continuing)"
  fi
else
  print_warning "deploy-network-policies.sh not found, skipping network policy deployment"
fi

# =============================================================================
# Create tenant DNS records (Cloudflare API)
# =============================================================================
# Validate Cloudflare IP ranges before creating DNS records (firewall depends on these)
print_status "Validating Cloudflare IP ranges..."
"$REPO_ROOT/scripts/check-cloudflare-ips" || { print_error "Cloudflare IPs changed. Run: ./scripts/check-cloudflare-ips --update"; exit 1; }

# Each tenant needs DNS records for their subdomains pointing to the ingress
print_status "Creating tenant DNS records..."

# Get the ingress IP from the cluster
INGRESS_IP=$(kubectl get service -n "$NS_INGRESS" ingress-nginx-controller -o jsonpath='{.status.loadBalancer.ingress[0].ip}' 2>/dev/null || echo "")
if [ -z "$INGRESS_IP" ]; then
  print_warning "Could not get ingress IP - DNS records will not be created"
  print_warning "You may need to create DNS records manually for $TENANT_DOMAIN"
else
  print_status "Ingress IP: $INGRESS_IP"

  # Load shared DNS functions (create_dns_record, create_srv_record, create_mx_record)
  source "${REPO_ROOT}/scripts/lib/dns.sh"

  # Create lb1 A record for this tenant's domain
  if [ -n "$TENANT_ENV_DNS_LABEL" ] && [ "$TENANT_ENV_DNS_LABEL" != "null" ]; then
    LB1_RECORD="lb1.${TENANT_ENV_DNS_LABEL}.${TENANT_DOMAIN}"
  else
    LB1_RECORD="lb1.prod.${TENANT_DOMAIN}"
  fi
  # Cloudflare proxy: prod only (Universal SSL covers *.domain but not *.dev.domain)
  if [ -z "$TENANT_ENV_DNS_LABEL" ] || [ "$TENANT_ENV_DNS_LABEL" = "null" ]; then
    CF_PROXIED="true"
  else
    CF_PROXIED="false"
  fi

  create_dns_record "$LB1_RECORD" "A" "$INGRESS_IP" "$CF_PROXIED"
  print_status "Created lb1 A record: $LB1_RECORD -> $INGRESS_IP (proxied=$CF_PROXIED)"

  # Create CNAME records for all tenant subdomains pointing to lb1
  # Note: 'mail' is excluded — its A record is created above alongside the MX record
  PROXIED_SUBDOMAINS="matrix synapse docs files auth home admin account webmail calendar jitsi office"
  DNS_ONLY_SUBDOMAINS="imap smtp"

  for subdomain in $PROXIED_SUBDOMAINS; do
    if [ -n "$TENANT_ENV_DNS_LABEL" ] && [ "$TENANT_ENV_DNS_LABEL" != "null" ]; then
      record_name="${subdomain}.${TENANT_ENV_DNS_LABEL}.${TENANT_DOMAIN}"
    else
      record_name="${subdomain}.${TENANT_DOMAIN}"
    fi
    create_dns_record "$record_name" "CNAME" "$LB1_RECORD" "$CF_PROXIED"
  done

  for subdomain in $DNS_ONLY_SUBDOMAINS; do
    if [ -n "$TENANT_ENV_DNS_LABEL" ] && [ "$TENANT_ENV_DNS_LABEL" != "null" ]; then
      record_name="${subdomain}.${TENANT_ENV_DNS_LABEL}.${TENANT_DOMAIN}"
    else
      record_name="${subdomain}.${TENANT_DOMAIN}"
    fi
    create_dns_record "$record_name" "CNAME" "$LB1_RECORD" "false"
  done

  # Create mail DNS records (A record for MX target + MX record)
  if [ "$MAIL_ENABLED" = "true" ]; then
    # Load Postfix relay VM IP from terraform outputs (for the mail A record)
    if [ -z "${POSTFIX_RELAY_SERVER_IP:-}" ]; then
      _tf_out="${MT_TERRAFORM_OUTPUTS_FILE:-}"
      if [ -z "$_tf_out" ] && [ -n "${MT_INFRA_CONFIG:-}" ]; then
        _tf_out="${MT_INFRA_CONFIG%/*}/terraform-outputs.${MT_ENV}.env"
      fi
      if [ -n "$_tf_out" ] && [ -f "$_tf_out" ]; then
        # shellcheck disable=SC1090
        source "$_tf_out"
      fi
    fi

    MX_HOST="${MAIL_HOST}"

    # Create/update the mail A record pointing to the Postfix relay VM
    if [ -n "${POSTFIX_RELAY_SERVER_IP:-}" ] && [ "${POSTFIX_RELAY_SERVER_IP}" != "null" ]; then
      create_dns_record "$MX_HOST" "A" "$POSTFIX_RELAY_SERVER_IP"
      print_status "Updated DNS: $MX_HOST -> $POSTFIX_RELAY_SERVER_IP"
    else
      print_warning "POSTFIX_RELAY_SERVER_IP not available — skipping mail A record for $MX_HOST"
    fi

    print_status "Creating MX record for $EMAIL_DOMAIN..."
    create_mx_record "$EMAIL_DOMAIN" "$MX_HOST" 10

    # ==========================================================================
    # Create SRV records for mail client autodiscovery (RFC 6186)
    # ==========================================================================
    print_status "Creating SRV records for mail autodiscovery..."

    if [ -z "$STALWART_IMAPS_APP_PORT" ] || [ "$STALWART_IMAPS_APP_PORT" = "null" ]; then
      print_warning "App password ports not configured in tenant config - skipping SRV records"
      print_warning "Add resources.stalwart.{imaps_app_port,submission_app_port} to tenant config"
    else
      create_srv_record "_imaps" "_tcp" "$EMAIL_DOMAIN" 0 1 "$STALWART_IMAPS_APP_PORT" "$IMAP_HOST"
      create_srv_record "_submission" "_tcp" "$EMAIL_DOMAIN" 0 1 "$STALWART_SUBMISSION_APP_PORT" "$SMTP_HOST"

      print_success "Mail autodiscovery SRV records created for $EMAIL_DOMAIN"
      print_status "Email clients supporting RFC 6186 will auto-discover:"
      print_status "  IMAPS: $IMAP_HOST:$STALWART_IMAPS_APP_PORT"
      print_status "  Submission: $SMTP_HOST:$STALWART_SUBMISSION_APP_PORT (STARTTLS)"
    fi
  fi

  # Base domain (e.g., example.com) is managed by Terraform as a CNAME to www
  # (external website). Do NOT create an A record here — it would conflict.

  print_success "Tenant DNS records created/updated"

  # =============================================================================
  # Email: Create SPF/DKIM/DMARC DNS records for tenant
  # =============================================================================
  print_status "Email: Creating email authentication DNS records for $EMAIL_DOMAIN..."

  # Read DKIM keys from tenant secrets
  DKIM_PRIVATE_KEY=$(yq '.dkim.private_key' "$TENANT_SECRETS")
  DKIM_PUBLIC_KEY=$(yq '.dkim.public_key' "$TENANT_SECRETS")

  if [ -z "$DKIM_PRIVATE_KEY" ] || [ "$DKIM_PRIVATE_KEY" = "null" ]; then
    print_warning "Missing 'dkim.private_key' in tenant secrets - email signing will not work"
    print_warning "Generate with: openssl genrsa 2048"
  elif [ -z "$DKIM_PUBLIC_KEY" ] || [ "$DKIM_PUBLIC_KEY" = "null" ]; then
    print_warning "Missing 'dkim.public_key' in tenant secrets - email signing will not work"
  else
    # Get MX mail host from shared infrastructure
    if [ "$MT_ENV" = "prod" ]; then
      MAIL_RELAY_HOST="mail.${INFRA_DOMAIN}"
    else
      MAIL_RELAY_HOST="mail.${MT_ENV}.${INFRA_DOMAIN}"
    fi

    # Create/update SPF record
    SPF_CONTENT="v=spf1 a:mail.${INFRA_DOMAIN} a:mail.dev.${INFRA_DOMAIN} include:_spf.mx.cloudflare.net ~all"
    create_dns_record "${EMAIL_DOMAIN}" "TXT" "$SPF_CONTENT"
    print_status "SPF record created for ${EMAIL_DOMAIN}"

    # Create/update DKIM record
    DKIM_CONTENT="v=DKIM1; k=rsa; p=${DKIM_PUBLIC_KEY}"
    create_dns_record "default._domainkey.${EMAIL_DOMAIN}" "TXT" "$DKIM_CONTENT"
    print_status "DKIM record created for default._domainkey.${EMAIL_DOMAIN}"

    # Create/update DMARC record
    DMARC_CONTENT="v=DMARC1; p=quarantine; rua=mailto:postmaster@${EMAIL_DOMAIN}; ruf=mailto:postmaster@${EMAIL_DOMAIN}; sp=quarantine; adkim=r; aspf=r"
    create_dns_record "_dmarc.${EMAIL_DOMAIN}" "TXT" "$DMARC_CONTENT"
    print_status "DMARC record created for _dmarc.${EMAIL_DOMAIN}"

    print_success "Email DNS records created for $EMAIL_DOMAIN"

    # =============================================================================
    # Email: Create/update DKIM key secret and OpenDKIM config
    # =============================================================================
    print_status "Email: Configuring DKIM signing for $EMAIL_DOMAIN..."

    kubectl create secret generic "dkim-key-${TENANT_NAME}" \
      -n "$NS_MAIL" \
      --from-literal="dkim.private=${DKIM_PRIVATE_KEY}" \
      --dry-run=client -o yaml | kubectl apply -f -
    print_status "DKIM key secret created: dkim-key-${TENANT_NAME}"

    # Patch OpenDKIM ConfigMap to include this tenant's email domain
    CURRENT_SIGNING=$(kubectl get configmap opendkim-config -n "$NS_MAIL" -o jsonpath='{.data.SigningTable}' 2>/dev/null || echo "")
    CURRENT_KEYTABLE=$(kubectl get configmap opendkim-config -n "$NS_MAIL" -o jsonpath='{.data.KeyTable}' 2>/dev/null || echo "")

    if echo "$CURRENT_SIGNING" | grep -q "$EMAIL_DOMAIN"; then
      print_status "OpenDKIM already configured for $EMAIL_DOMAIN"
    else
      NEW_SIGNING="${CURRENT_SIGNING}
*@${EMAIL_DOMAIN} default._domainkey.${EMAIL_DOMAIN}"
      NEW_KEYTABLE="${CURRENT_KEYTABLE}
default._domainkey.${EMAIL_DOMAIN} ${EMAIL_DOMAIN}:default:/etc/dkim-keys/${TENANT_NAME}/dkim.private"

      PATCH_JSON=$(jq -n \
        --arg signing "$NEW_SIGNING" \
        --arg keytable "$NEW_KEYTABLE" \
        '{"data": {"SigningTable": $signing, "KeyTable": $keytable}}')

      kubectl patch configmap opendkim-config -n "$NS_MAIL" --type=merge -p "$PATCH_JSON"

      print_status "OpenDKIM ConfigMap updated for $EMAIL_DOMAIN"
    fi

    # Patch Postfix deployment to mount this tenant's DKIM key
    EXISTING_VOLUMES=$(kubectl get deployment postfix -n "$NS_MAIL" -o jsonpath='{.spec.template.spec.volumes[*].name}' 2>/dev/null || echo "")
    if echo "$EXISTING_VOLUMES" | grep -q "dkim-key-${TENANT_NAME}"; then
      print_status "DKIM key volume already mounted for $TENANT_NAME"
    else
      print_status "Patching Postfix deployment to mount DKIM key for $TENANT_NAME..."
      kubectl patch deployment postfix -n "$NS_MAIL" --type=json -p="[
        {\"op\": \"add\", \"path\": \"/spec/template/spec/volumes/-\", \"value\": {
          \"name\": \"dkim-key-${TENANT_NAME}\",
          \"secret\": {
            \"secretName\": \"dkim-key-${TENANT_NAME}\",
            \"items\": [{\"key\": \"dkim.private\", \"path\": \"dkim.private\"}]
          }
        }},
        {\"op\": \"add\", \"path\": \"/spec/template/spec/containers/0/volumeMounts/-\", \"value\": {
          \"name\": \"dkim-key-${TENANT_NAME}\",
          \"mountPath\": \"/etc/dkim-keys/${TENANT_NAME}\",
          \"readOnly\": true
        }}
      ]" 2>/dev/null || print_warning "Could not patch Postfix deployment - may need manual configuration"
      print_status "Postfix deployment patched with DKIM key mount"
    fi

    # =============================================================================
    # Email: Configure Postfix mail routing for all tenants
    # =============================================================================
    print_status "Email: Configuring Postfix mail routing for all tenants..."
    if [ -x "$REPO_ROOT/scripts/configure-mail-routing" ]; then
      "$REPO_ROOT/scripts/configure-mail-routing" -e "$MT_ENV" --nesting-level=$((MT_NESTING_LEVEL+1)) 2>&1 | sed 's/^/  /'
      print_status "Postfix mail routing configured"
    else
      print_warning "configure-mail-routing script not found - skipping routing config"
      kubectl rollout restart deployment/postfix -n "$NS_MAIL" 2>/dev/null || print_warning "Could not restart Postfix (may not exist yet)"
    fi

    print_success "Email signing configured for $EMAIL_DOMAIN"
  fi
fi

# Apply PriorityClass for critical services (must exist before JVB/y-provider deploy)
print_status "Applying PriorityClass for critical services..."
kubectl apply -f "$REPO_ROOT/apps/manifests/priority-class.yaml"

# Wait for helm repo update to complete before first helm operation
if [ -n "${HELM_REPO_UPDATE_PID:-}" ]; then
  print_status "Waiting for helm repo update to complete..."
  wait $HELM_REPO_UPDATE_PID 2>/dev/null || true
  print_status "Helm repo update complete"
fi

# Export flag to tell sub-scripts to skip repo updates
export SKIP_HELM_REPO_UPDATE=true

# Deploy Docs (backend, frontend, y-provider, Redis)
print_status "Docs: deploy to $NS_DOCS namespace"
if [ ! -f "$REPO_ROOT/apps/deploy-docs.sh" ]; then
  print_error "deploy-docs.sh not found at $REPO_ROOT/apps/deploy-docs.sh"
  exit 1
fi
if ! "$REPO_ROOT/apps/deploy-docs.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)); then
  print_error "deploy-docs.sh failed"
  exit 1
fi

# Keycloak: create Google OAuth secret (required for realm import)
print_status "Keycloak: create Google OAuth secret (required for realm import)"
if ! kubectl get secret keycloak-google-oauth -n "$NS_AUTH" >/dev/null 2>&1; then
  if [ -f "$REPO_ROOT/docs/keycloak-google-oauth-secret.yaml" ]; then
    cat "$REPO_ROOT/docs/keycloak-google-oauth-secret.yaml" | sed "s/namespace: docs/namespace: $NS_AUTH/" | kubectl apply -f -
    print_status "Google OAuth secret created in namespace $NS_AUTH"
  else
    print_warning "keycloak-google-oauth-secret.yaml not found, realm import may fail"
  fi
else
  print_status "Google OAuth secret already exists"
fi

# Note: Keycloak theme ConfigMap is created by deploy_infra (shared infrastructure)
# Note: Keycloak ingress patching moved to AFTER helmfile tier=apps to avoid conflicts

# Keycloak: import realm configuration for this tenant
print_status "Keycloak: import realm configuration"
if [ ! -f "$REPO_ROOT/docs/import-keycloak-realm.sh" ]; then
  print_error "import-keycloak-realm.sh not found at $REPO_ROOT/docs/import-keycloak-realm.sh"
  exit 1
fi
if ! MT_ENV="$MT_ENV" "$REPO_ROOT/docs/import-keycloak-realm.sh"; then
  print_error "import-keycloak-realm.sh failed"
  exit 1
fi

# ── Prep-only exit point ────────────────────────────────────────────
# When --prep-only is set, exit here. All prerequisites for parallel
# app deploys are now in place: namespaces, TLS cert, DNS records,
# DKIM/mail routing, Docs, and Keycloak realm.
if [ "$PREP_ONLY" = "true" ]; then
  print_success "Prep phase complete for tenant $TENANT_NAME (--prep-only)"
  print_status "Namespaces, TLS cert, DNS, DKIM, Docs, and Keycloak realm are ready."
  print_status "Individual app deploys can now run in parallel."
  exit 0
fi

fi  # end of FINALIZE_ONLY else block (skips infra verification + prep)

# ── Finalize-only: skip to finalize phase ────────────────────────────
# When --finalize-only is set, skip all app deploys and go straight to
# cleanup, endpoint probes, and health checks.
if [ "$FINALIZE_ONLY" != "true" ]; then
# ── BEGIN app deploys (skipped when --finalize-only) ─────────────────

# Deploy Collabora CODE (per-tenant office suite for in-browser document editing)
# Must come BEFORE Nextcloud so the richdocuments activate-config step can reach Collabora
if [ "$OFFICE_ENABLED" = "true" ]; then
  print_status "Collabora: deploying to $NS_OFFICE namespace"
  kubectl create namespace "$NS_OFFICE" --dry-run=client -o yaml | kubectl apply -f -
  pushd "$REPO_ROOT/apps" >/dev/null
    helmfile -e "$MT_ENV" -l name=collabora-online --skip-deps sync
  popd >/dev/null
  print_status "Collabora: waiting for pod readiness..."
  kubectl wait --for=condition=ready pod -l app.kubernetes.io/name=collabora-online \
    -n "$NS_OFFICE" --timeout=300s
  print_success "Collabora deployed"
else
  print_status "Collabora: skipping (features.office_enabled is not true)"
fi

# Deploy Nextcloud
print_status "Nextcloud: deploy to $NS_FILES namespace"
if [ ! -f "$REPO_ROOT/apps/deploy-nextcloud.sh" ]; then
  print_error "deploy-nextcloud.sh not found at $REPO_ROOT/apps/deploy-nextcloud.sh"
  exit 1
fi
if ! "$REPO_ROOT/apps/deploy-nextcloud.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)); then
  print_error "deploy-nextcloud.sh failed"
  exit 1
fi

# Deploy Matrix (Synapse + Element)
print_status "Matrix: deploy to $NS_MATRIX namespace"
if [ ! -f "$REPO_ROOT/apps/deploy-matrix.sh" ]; then
  print_error "deploy-matrix.sh not found at $REPO_ROOT/apps/deploy-matrix.sh"
  exit 1
fi
MATRIX_EXTRA_ARGS=""
if [ "$CREATE_ALERT_USER" = "true" ]; then
  MATRIX_EXTRA_ARGS="--create-alert-user"
fi
if ! "$REPO_ROOT/apps/deploy-matrix.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)) $MATRIX_EXTRA_ARGS; then
  print_error "deploy-matrix.sh failed"
  exit 1
fi

# Reload alertbot token if it was created by deploy-matrix.sh
if [ "$CREATE_ALERT_USER" = "true" ]; then
  MATRIX_ALERTMANAGER_ACCESS_TOKEN=$(yq '.alertbot.access_token // ""' "$TENANT_SECRETS")
  if [ -n "$MATRIX_ALERTMANAGER_ACCESS_TOKEN" ] && [ "$MATRIX_ALERTMANAGER_ACCESS_TOKEN" != "null" ]; then
    export MATRIX_ALERTMANAGER_ACCESS_TOKEN
  fi
fi

# Deploy Jitsi
print_status "Jitsi: deploy to $NS_JITSI namespace"
if [ ! -f "$REPO_ROOT/apps/deploy-jitsi.sh" ]; then
  print_error "deploy-jitsi.sh not found at $REPO_ROOT/apps/deploy-jitsi.sh"
  exit 1
fi
if ! "$REPO_ROOT/apps/deploy-jitsi.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)); then
  print_error "deploy-jitsi.sh failed"
  exit 1
fi

# Deploy Jitsi metrics exporter
print_status "Jitsi: deploy metrics exporter"
envsubst '${TURN_SERVER_IP}' < "$REPO_ROOT/apps/manifests/jitsi/jitsi-metrics-exporter.yaml" | \
  sed "s/namespace: matrix/namespace: $NS_JITSI/g" | kubectl apply -f -

if kubectl get deployment jitsi-metrics-exporter -n "$NS_JITSI" >/dev/null 2>&1; then
  kubectl rollout restart deployment/jitsi-metrics-exporter -n "$NS_JITSI"
fi

kubectl wait --for=condition=available deployment/jitsi-metrics-exporter -n "$NS_JITSI" --timeout=120s || print_warning "Metrics exporter may not be ready yet"

# Deploy ServiceMonitors
cat "$REPO_ROOT/apps/manifests/jitsi/jitsi-metrics-exporter-servicemonitor.yaml" | \
  sed "s/namespace: matrix/namespace: $NS_JITSI/g" | kubectl apply -f -
cat "$REPO_ROOT/apps/manifests/jitsi/jvb-servicemonitor.yaml" | \
  sed "s/namespace: matrix/namespace: $NS_JITSI/g" | kubectl apply -f -
cat "$REPO_ROOT/apps/manifests/jitsi/jicofo-servicemonitor.yaml" | \
  sed "s/namespace: matrix/namespace: $NS_JITSI/g" | kubectl apply -f -
cat "$REPO_ROOT/apps/manifests/jitsi/jitsi-alerting-rules.yaml" | \
  sed "s/namespace: matrix/namespace: $NS_JITSI/g" | kubectl apply -f -
# Clean up old PrometheusRule name (renamed from jitsi-turn-alerts to jitsi-alerts)
kubectl delete prometheusrule jitsi-turn-alerts -n "$NS_JITSI" 2>/dev/null || true

print_status "Jitsi monitoring resources deployed to namespace $NS_JITSI"

# =============================================================================
# Deploy Stalwart Mail Server (if enabled)
# =============================================================================
if [ "$MAIL_ENABLED" = "true" ]; then
  print_status "Stalwart: deploy to $NS_STALWART namespace"
  if [ -f "$REPO_ROOT/apps/deploy-stalwart.sh" ]; then
    if ! "$REPO_ROOT/apps/deploy-stalwart.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)); then
      print_error "deploy-stalwart.sh failed"
      exit 1
    fi
  else
    print_error "deploy-stalwart.sh not found at $REPO_ROOT/apps/deploy-stalwart.sh"
    exit 1
  fi
else
  print_status "Stalwart: skipping (features.mail_enabled is not true)"
fi

# =============================================================================
# Deploy Email Probe (if enabled) - non-fatal on failure
# =============================================================================
if [ "$EMAIL_PROBE_ENABLED" = "true" ] && [ "$MAIL_ENABLED" = "true" ]; then
  print_status "Email Probe: deploy to $NS_STALWART namespace"
  if [ -f "$REPO_ROOT/apps/deploy-email-probe.sh" ]; then
    if ! "$REPO_ROOT/apps/deploy-email-probe.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)); then
      print_warning "deploy-email-probe.sh failed (non-fatal, probe is monitoring-only)"
    fi
  else
    print_warning "deploy-email-probe.sh not found at $REPO_ROOT/apps/deploy-email-probe.sh"
  fi
else
  print_status "Email Probe: skipping (email_probe_enabled=$EMAIL_PROBE_ENABLED, mail_enabled=$MAIL_ENABLED)"
fi

# =============================================================================
# Deploy Roundcube Webmail (if enabled)
# =============================================================================
if [ "$WEBMAIL_ENABLED" = "true" ]; then
  print_status "Roundcube: deploy to $NS_WEBMAIL namespace"
  if [ -f "$REPO_ROOT/apps/deploy-roundcube.sh" ]; then
    if ! "$REPO_ROOT/apps/deploy-roundcube.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)); then
      print_error "deploy-roundcube.sh failed"
      exit 1
    fi
  else
    print_error "deploy-roundcube.sh not found at $REPO_ROOT/apps/deploy-roundcube.sh"
    exit 1
  fi
else
  print_status "Roundcube: skipping (features.webmail_enabled is not true)"
fi

# =============================================================================
# Deploy Calendar Automation (if enabled)
# =============================================================================
# Requires both Stalwart (IMAP) and Nextcloud (CalDAV) to be running.
# Processes iTIP email invitations and creates/updates/cancels CalDAV events.
if [ "$CALENDAR_ENABLED" = "true" ] && [ "$MAIL_ENABLED" = "true" ] && [ "$FILES_ENABLED" = "true" ]; then
  print_status "Calendar Automation: deploy to $NS_STALWART namespace"
  if [ -f "$REPO_ROOT/apps/deploy-calendar-automation.sh" ]; then
    if ! "$REPO_ROOT/apps/deploy-calendar-automation.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)); then
      print_warning "deploy-calendar-automation.sh failed (non-fatal, calendar invites will need manual processing)"
    fi
  else
    print_warning "deploy-calendar-automation.sh not found at $REPO_ROOT/apps/deploy-calendar-automation.sh"
  fi
else
  print_status "Calendar Automation: skipping (requires calendar_enabled=true, mail_enabled=true, files_enabled=true)"
fi

# Load platform release version (before portal deploys so RELEASE_VERSION is available to envsubst)
source "${REPO_ROOT}/scripts/lib/release.sh"
_mt_load_release_version
print_status "Release version: $RELEASE_VERSION"

# =============================================================================
# Deploy Admin Portal (if enabled)
# =============================================================================
if [ "$ADMIN_PORTAL_ENABLED" = "true" ]; then
  if ! "$REPO_ROOT/apps/deploy-admin-portal.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)); then
    print_error "deploy-admin-portal.sh failed"
    exit 1
  fi
else
  print_status "Admin Portal: skipping (features.admin_portal_enabled is not true)"
fi

# =============================================================================
# Deploy Account Portal (if enabled)
# =============================================================================
if [ "$ACCOUNT_PORTAL_ENABLED" = "true" ]; then
  if ! "$REPO_ROOT/apps/deploy-account-portal.sh" -e "$MT_ENV" -t "$MT_TENANT" --nesting-level=$((MT_NESTING_LEVEL+1)); then
    print_error "deploy-account-portal.sh failed"
    exit 1
  fi
else
  print_status "Account Portal: skipping (features.account_portal_enabled is not true)"
fi

# ── END app deploys ──────────────────────────────────────────────────
fi  # end of FINALIZE_ONLY != true

# =============================================================================
# Finalize: Cleanup, endpoint probes, and health checks
# =============================================================================

# =============================================================================
# Cleanup old per-service Certificate resources (replaced by wildcard cert)
# =============================================================================
print_status "Cleaning up old per-service Certificate resources..."
kubectl delete certificate synapse-tls element-tls matrix-wellknown-tls synapse-admin-tls \
  -n "$NS_MATRIX" --ignore-not-found 2>/dev/null || true
kubectl delete certificate stalwart-tls stalwart-webadmin-tls \
  -n "$NS_STALWART" --ignore-not-found 2>/dev/null || true
kubectl delete certificate docs-tls -n "$NS_DOCS" --ignore-not-found 2>/dev/null || true
kubectl delete certificate files-tls calendar-tls -n "$NS_FILES" --ignore-not-found 2>/dev/null || true
kubectl delete certificate jitsi-tls -n "$NS_JITSI" --ignore-not-found 2>/dev/null || true
kubectl delete certificate roundcube-tls -n "$NS_WEBMAIL" --ignore-not-found 2>/dev/null || true
kubectl delete certificate admin-portal-tls account-portal-tls -n "$NS_ADMIN" --ignore-not-found 2>/dev/null || true
kubectl delete certificate "${AUTH_HOST}-tls" -n "$NS_AUTH" --ignore-not-found 2>/dev/null || true
print_status "Old certificate resources cleaned up"

# Wait for wildcard TLS secret to be available in NS_MATRIX
print_status "Verifying wildcard TLS secret is available..."
CERT_TIMEOUT=300
attempts=0
while [ $attempts -lt $((CERT_TIMEOUT / 5)) ]; do
  if kubectl get secret "wildcard-tls-${TENANT_NAME}" -n "$NS_MATRIX" >/dev/null 2>&1; then
    print_status "Wildcard TLS secret wildcard-tls-${TENANT_NAME} is ready"
    break
  fi
  attempts=$((attempts + 1))
  sleep 5
done

# =============================================================================
# Deploy per-tenant endpoint Probe CRDs (Blackbox Exporter monitoring)
# =============================================================================
echo ""
print_status "Deploying endpoint monitoring probes..."

# Build probe targets list dynamically based on feature flags
ENDPOINT_PROBE_TARGETS=""
ENDPOINT_PROBE_TARGETS="${ENDPOINT_PROBE_TARGETS}        - https://${MATRIX_HOST}/
"
ENDPOINT_PROBE_TARGETS="${ENDPOINT_PROBE_TARGETS}        - https://${DOCS_HOST}/
"
ENDPOINT_PROBE_TARGETS="${ENDPOINT_PROBE_TARGETS}        - https://${FILES_HOST}/status.php
"
ENDPOINT_PROBE_TARGETS="${ENDPOINT_PROBE_TARGETS}        - https://${AUTH_HOST}/realms/${TENANT_KEYCLOAK_REALM}
"
if [ "$JITSI_ENABLED" = "true" ]; then
  ENDPOINT_PROBE_TARGETS="${ENDPOINT_PROBE_TARGETS}        - https://${JITSI_HOST}/
"
fi
if [ "$WEBMAIL_ENABLED" = "true" ]; then
  ENDPOINT_PROBE_TARGETS="${ENDPOINT_PROBE_TARGETS}        - https://${WEBMAIL_HOST}/
"
fi
if [ "$ADMIN_PORTAL_ENABLED" = "true" ]; then
  ENDPOINT_PROBE_TARGETS="${ENDPOINT_PROBE_TARGETS}        - https://${ADMIN_HOST}/
"
fi
if [ "$ACCOUNT_PORTAL_ENABLED" = "true" ]; then
  ENDPOINT_PROBE_TARGETS="${ENDPOINT_PROBE_TARGETS}        - https://${ACCOUNT_HOST}/
"
fi
if [ "$CALENDAR_ENABLED" = "true" ]; then
  ENDPOINT_PROBE_TARGETS="${ENDPOINT_PROBE_TARGETS}        - https://${CALENDAR_HOST}/status.php
"
fi
if [ "$OFFICE_ENABLED" = "true" ]; then
  ENDPOINT_PROBE_TARGETS="${ENDPOINT_PROBE_TARGETS}        - https://${OFFICE_HOST}/
"
fi
export ENDPOINT_PROBE_TARGETS

# Select probe module names: dev uses SOCKS-proxied _ext variants to bypass
# kube-proxy short-circuit (no PROXY header); prod uses direct modules.
if [ "$MT_ENV" = "prod" ]; then
  export PROBE_MODULE_HTTP="http_2xx"
  export PROBE_MODULE_SYNAPSE="http_synapse"
else
  export PROBE_MODULE_HTTP="http_2xx_ext"
  export PROBE_MODULE_SYNAPSE="http_synapse_ext"
fi

envsubst < "$REPO_ROOT/apps/manifests/monitoring/endpoint-probes.yaml.tpl" | kubectl apply -f - && \
  print_status "Endpoint probes deployed for tenant $TENANT" || \
  print_warning "Could not deploy endpoint probes (blackbox-exporter may not be installed yet)"

echo ""
print_success "Tenant $TENANT deployed for $MT_ENV environment!"
echo ""
echo "Tenant namespaces:"
echo "  - $NS_MATRIX (Synapse, Element)"
echo "  - $NS_JITSI (Jitsi)"
echo "  - $NS_DOCS (Docs backend/frontend)"
echo "  - $NS_FILES (Nextcloud)"
if [ "$MAIL_ENABLED" = "true" ]; then
  echo "  - $NS_STALWART (Stalwart Mail)"
fi
if [ "$WEBMAIL_ENABLED" = "true" ]; then
  echo "  - $NS_WEBMAIL (Roundcube Webmail)"
fi
if [ "$ADMIN_PORTAL_ENABLED" = "true" ]; then
  echo "  - $NS_ADMIN (Admin Portal)"
fi
if [ "$OFFICE_ENABLED" = "true" ]; then
  echo "  - $NS_OFFICE (Collabora CODE)"
fi
echo ""
echo "URLs:"
echo "  - Matrix: https://$MATRIX_HOST"
echo "  - Synapse Admin: https://$SYNAPSE_ADMIN_HOST"
echo "  - Docs: https://docs.${TENANT_ENV_DNS_LABEL:+$TENANT_ENV_DNS_LABEL.}$TENANT_DOMAIN"
echo "  - Files: https://files.${TENANT_ENV_DNS_LABEL:+$TENANT_ENV_DNS_LABEL.}$TENANT_DOMAIN"
if [ "$MAIL_ENABLED" = "true" ]; then
  echo "  - Mail Admin: https://$MAIL_HOST"
fi
if [ "$WEBMAIL_ENABLED" = "true" ]; then
  echo "  - Webmail: https://$WEBMAIL_HOST"
fi
if [ "$ADMIN_PORTAL_ENABLED" = "true" ]; then
  echo "  - Admin Portal: https://$ADMIN_HOST"
fi
if [ "$OFFICE_ENABLED" = "true" ]; then
  echo "  - Office: https://$OFFICE_HOST"
fi
# Run post-deploy health check (non-blocking)
echo ""
print_status "Running post-deploy health check..."
"$REPO_ROOT/scripts/check-health" -e "$MT_ENV" -t "$MT_TENANT" || print_warning "Issues detected - review above"

# Run post-deploy endpoint verification (non-blocking)
echo ""
print_status "Verifying external endpoint reachability..."
"$REPO_ROOT/scripts/verify-endpoints" -e "$MT_ENV" -t "$MT_TENANT" || print_warning "Some endpoints not reachable - review above"

echo ""
echo "To check status:"
echo "  kubectl get pods -n $NS_MATRIX"
echo "  kubectl get pods -n $NS_JITSI"
echo "  kubectl get pods -n $NS_DOCS"
echo "  kubectl get pods -n $NS_FILES"
if [ "$MAIL_ENABLED" = "true" ]; then
  echo "  kubectl get pods -n $NS_STALWART"
fi
if [ "$WEBMAIL_ENABLED" = "true" ]; then
  echo "  kubectl get pods -n $NS_WEBMAIL"
fi
if [ "$ADMIN_PORTAL_ENABLED" = "true" ]; then
  echo "  kubectl get pods -n $NS_ADMIN"
fi
if [ "$OFFICE_ENABLED" = "true" ]; then
  echo "  kubectl get pods -n $NS_OFFICE"
fi
