<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MotherTree</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="bg-white min-h-screen flex items-center justify-center p-8">
  <div class="bg-cream rounded-xl shadow-lg p-8 max-w-md w-full">
    <div class="text-center mb-6">
      <h1 class="text-3xl text-sage mb-2">MotherTree</h1>
      <p class="text-warm-gray">Sign in with email link</p>
    </div>

    <% if (error) { %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
        <div class="flex items-center">
          <svg class="w-5 h-5 text-red-600 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span class="text-red-800"><%= error %></span>
        </div>
      </div>
    <% } %>

    <p class="text-warm-gray text-sm mb-6">
      Enter your MotherTree email address and we'll send you a secure link to sign in.
    </p>

    <form method="POST" action="/magic-link-login" class="space-y-4">
      <% if (next) { %>
        <input type="hidden" name="next" value="<%= next %>">
      <% } %>
      <div>
        <label for="magicLinkEmail" class="block text-sm font-medium text-gray-700 mb-1">
          Your MotherTree Email
        </label>
        <input
          type="email"
          id="magicLinkEmail"
          name="email"
          required
          placeholder="you@example.com"
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sage focus:border-transparent outline-none"
        >
      </div>

      <button
        type="submit"
        class="w-full bg-sage text-white px-6 py-3 rounded-lg hover:bg-sage-dark transition-colors font-medium"
      >
        Send Sign-In Link
      </button>
    </form>

    <div class="mt-6 pt-4 border-t border-gray-200 text-center">
      <a href="/" class="text-sm text-warm-gray hover:text-sage">
        &larr; Back to Sign In
      </a>
    </div>

    <%- include('partials/policy-footer') %>
  </div>
</body>
</html>
