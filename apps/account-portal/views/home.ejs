<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MotherTree</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="bg-sage/10 min-h-screen p-8">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <header class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl text-sage">Welcome, <%= user.name %></h1>
        <p class="text-warm-gray mt-1"><%= user.email %></p>
      </div>
      <div class="flex gap-4">
        <a href="/auth/logout" class="text-warm-gray hover:text-sage-dark transition-colors">Sign Out</a>
      </div>
    </header>

    <!-- App Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

      <% if (elementHost) { %>
      <a href="https://<%= elementHost %>" class="bg-cream rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow group block">
        <div class="flex items-center gap-4 mb-3">
          <div class="w-10 h-10 rounded-lg bg-sage flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <h2 class="text-xl text-coal group-hover:text-sage-dark transition-colors">Chat</h2>
        </div>
        <p class="text-warm-gray text-sm">Send messages and collaborate in real time.</p>
      </a>
      <% } %>

      <% if (webmailHost) { %>
      <a href="https://<%= webmailHost %>" class="bg-cream rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow group block">
        <div class="flex items-center gap-4 mb-3">
          <div class="w-10 h-10 rounded-lg bg-sage flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-xl text-coal group-hover:text-sage-dark transition-colors">Email</h2>
        </div>
        <p class="text-warm-gray text-sm">Read and send email from your browser.</p>
      </a>
      <% } %>

      <% if (docsHost) { %>
      <a href="https://<%= docsHost %>" class="bg-cream rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow group block">
        <div class="flex items-center gap-4 mb-3">
          <div class="w-10 h-10 rounded-lg bg-sage flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h2 class="text-xl text-coal group-hover:text-sage-dark transition-colors">Documents</h2>
        </div>
        <p class="text-warm-gray text-sm">Create and edit documents together.</p>
      </a>
      <% } %>

      <% if (filesHost) { %>
      <a href="https://<%= filesHost %>" class="bg-cream rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow group block">
        <div class="flex items-center gap-4 mb-3">
          <div class="w-10 h-10 rounded-lg bg-sage flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
            </svg>
          </div>
          <h2 class="text-xl text-coal group-hover:text-sage-dark transition-colors">Files</h2>
        </div>
        <p class="text-warm-gray text-sm">Store and share files securely.</p>
      </a>
      <% } %>

      <% if (jitsiHost) { %>
      <a href="https://<%= jitsiHost %>" class="bg-cream rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow group block">
        <div class="flex items-center gap-4 mb-3">
          <div class="w-10 h-10 rounded-lg bg-sage flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-xl text-coal group-hover:text-sage-dark transition-colors">Video</h2>
        </div>
        <p class="text-warm-gray text-sm">Start or join a video call.</p>
      </a>
      <% } %>

      <% if (filesHost) { %>
      <a href="https://<%= filesHost %>/apps/calendar/" class="bg-cream rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow group block">
        <div class="flex items-center gap-4 mb-3">
          <div class="w-10 h-10 rounded-lg bg-sage flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-xl text-coal group-hover:text-sage-dark transition-colors">Calendar</h2>
        </div>
        <p class="text-warm-gray text-sm">Manage events and schedules.</p>
      </a>
      <% } %>

      <a href="/app-passwords" class="bg-cream rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow group block">
        <div class="flex items-center gap-4 mb-3">
          <div class="w-10 h-10 rounded-lg bg-sage flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h2 class="text-xl text-coal group-hover:text-sage-dark transition-colors">Device Passwords</h2>
        </div>
        <p class="text-warm-gray text-sm">Manage passwords for email and calendar apps.</p>
      </a>

    </div>

    <%- include('partials/policy-footer') %>
  </div>
</body>
</html>
