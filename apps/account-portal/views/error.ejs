<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="bg-white min-h-screen flex items-center justify-center p-8">
  <div class="bg-cream rounded-xl shadow-lg p-8 max-w-md w-full text-center">
    <h1 class="text-2xl text-red-600 mb-4"><%= title %></h1>
    <p class="text-warm-gray mb-8"><%= message %></p>

    <a href="/auth/logout" class="inline-block bg-sage text-white px-6 py-3 rounded-lg hover:bg-sage-dark transition-colors">
      Logout
    </a>
  </div>
</body>
</html>
