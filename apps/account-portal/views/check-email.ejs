<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MotherTree</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="bg-white min-h-screen flex items-center justify-center p-8">
  <div class="bg-cream rounded-xl shadow-lg p-8 max-w-md w-full">
    <div class="text-center mb-6">
      <h1 class="text-3xl text-sage mb-2">MotherTree</h1>
      <p class="text-warm-gray">Check your email</p>
    </div>

    <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-6">
      <div class="flex items-center mb-2">
        <svg class="w-5 h-5 text-green-600 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        <span class="text-green-800 font-medium">Sign-in link sent</span>
      </div>
      <p class="text-green-700 text-sm">
        We've sent a sign-in link to <strong><%= emailHint %></strong>.
      </p>
      <p class="text-green-700 text-sm mt-2">
        Click the link in the email to complete your account setup.
      </p>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
      <p class="text-amber-800 text-sm">
        <strong>Tip:</strong> The link expires in 15 minutes. Check your spam folder if you don't see the email.
      </p>
    </div>

    <%- include('partials/policy-footer') %>
  </div>
</body>
</html>
