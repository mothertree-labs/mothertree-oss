# Account Portal Environment Variables - LOCAL DEVELOPMENT

# Server
PORT=3000
BASE_URL=http://localhost:3000

# Session
SESSION_SECRET=dev-local-secret-change-in-production

# Redis (optional - running Redis locally is not needed)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Keycloak OIDC
KEYCLOAK_ISSUER=http://localhost:8080/realms/dev
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=dev
KEYCLOAK_CLIENT_ID=account-portal
KEYCLOAK_CLIENT_SECRET=will-be-replaced-by-the-startup-script

# Tenant - must be "localhost" for local origin verification
TENANT_DOMAIN=localhost
EMAIL_DOMAIN=localhost

# App hosts - localhost for testing (links will open new tabs regardless of whether they resolve)
# These don't need to work on localhast - just placeholders
ELEMENT_HOST=element.localhost
WEBMAIL_HOST=webmail.localhost
DOCS_HOST=docs.localhost
FILES_HOST=files.localhost
JITSI_HOST=jitsi.localhost

# Mail server (for display purposes only - not functional in local dev)
MAIL_HOST=mail.localhost
IMAP_HOST=imap.localhost
SMTP_HOST=smtp.localhost
STALWART_IMAPS_PORT=9930
STALWART_SUBMISSION_PORT=58700
STALWART_IMAPS_APP_PORT=9940
STALWART_SUBMISSION_APP_PORT=5880

# Stalwart (optional - not needed when running locally)
# STALWART_API_URL=http://stalwart.tn-example-mail.svc.cluster.local:8080
# STALWART_ADMIN_PASSWORD=change-me
