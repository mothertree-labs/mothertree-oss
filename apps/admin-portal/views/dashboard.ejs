<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - MotherTree Admin</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/tailwind.css">
</head>
<body class="bg-page min-h-screen p-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <header class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-semibold text-coal">mothertree admin</h1>
        <p class="text-warm-gray mt-1">Welcome, <%= user.name || user.email %></p>
      </div>
      <a href="/auth/logout" class="text-warm-gray hover:text-coal-dark transition-colors">
        Sign Out
      </a>
    </header>

    <!-- Invite User Form -->
    <div class="bg-cream rounded-xl shadow-lg p-8 mb-8">
      <h2 class="text-2xl text-coal mb-6">Invite New User</h2>
      
      <form id="inviteForm" class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-warm-gray mb-2">First Name</label>
            <input type="text" name="firstName" required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-sage">
          </div>
          <div>
            <label class="block text-warm-gray mb-2">Last Name</label>
            <input type="text" name="lastName" required
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-sage">
          </div>
        </div>
        
        <div>
          <label class="block text-warm-gray mb-2">Tenant Email (login email)</label>
          <div class="flex items-center">
            <input type="text" id="emailUsername" required placeholder="username"
              class="flex-1 px-4 py-2 border border-gray-300 rounded-l-lg focus:outline-none focus:ring-2 focus:ring-sage"
              pattern="[a-zA-Z0-9._-]+" title="Letters, numbers, dots, underscores, and hyphens only">
            <span class="px-4 py-2 bg-gray-100 border border-l-0 border-gray-300 rounded-r-lg text-warm-gray" id="emailDomain">@<%= process.env.EMAIL_DOMAIN || process.env.TENANT_DOMAIN || '' %></span>
            <input type="hidden" name="email" id="fullEmail">
          </div>
        </div>
        
        <div>
          <label class="block text-warm-gray mb-2">Recovery Email (for invitation)</label>
          <input type="email" name="recoveryEmail" required placeholder="personal@gmail.com"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-sage">
        </div>
        
        <div id="formMessage" class="hidden p-4 rounded-lg"></div>
        
        <button type="submit" 
          class="w-full bg-sage text-white px-6 py-3 rounded-lg hover:bg-sage-dark transition-colors">
          Send Invitation
        </button>
      </form>
    </div>

    <!-- Members List -->
    <div class="bg-cream rounded-xl shadow-lg p-8 mb-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl text-coal">Members</h2>
        <button id="backfillBtn" class="text-sm px-4 py-2 border border-sage text-coal rounded-lg hover:bg-sage hover:text-white transition-colors">
          Apply Default Quotas
        </button>
      </div>

      <div id="membersList" class="space-y-4">
        <p class="text-warm-gray">Loading members...</p>
      </div>
    </div>

    <!-- Quota Edit Modal -->
    <div id="quotaModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
      <div class="bg-cream rounded-xl shadow-lg p-6 w-96">
        <h3 class="text-lg text-coal mb-4">Edit Email Quota</h3>
        <p class="text-sm text-warm-gray mb-4" id="quotaModalEmail"></p>
        <div class="mb-4">
          <label class="block text-warm-gray mb-2">Quota (MB)</label>
          <input type="number" id="quotaInput" min="0" step="1"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-sage"
            placeholder="0 = unlimited">
          <p class="text-xs text-warm-gray mt-1">Set to 0 for unlimited storage</p>
        </div>
        <div class="flex gap-3 justify-end">
          <button id="quotaCancelBtn" class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">Cancel</button>
          <button id="quotaSaveBtn" class="px-4 py-2 bg-sage text-white rounded-lg hover:bg-sage-dark transition-colors">Save</button>
        </div>
      </div>
    </div>

    <!-- Guests List -->
    <div class="bg-cream rounded-xl shadow-lg p-8">
      <h2 class="text-2xl text-coal mb-6">Guests</h2>
      <p class="text-warm-gray text-sm mb-4">External collaborators with access to shared documents only. Guests can self-register at <a href="#" id="guestRegisterLink" class="text-coal hover:text-coal-dark underline">account portal</a>.</p>

      <div id="guestsList" class="space-y-4">
        <p class="text-warm-gray">Loading guests...</p>
      </div>
    </div>

    <%- include('partials/policy-footer') %>
  </div>

  <script>
    // Escape HTML to prevent XSS when inserting user-supplied data into the DOM
    function escapeHtml(str) {
      if (!str) return '';
      const div = document.createElement('div');
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
    }

    // Load users on page load
    async function loadUsers() {
      try {
        const response = await fetch('/api/users');
        const users = await response.json();

        const members = users.filter(u => u.userType !== 'guest');
        const guests = users.filter(u => u.userType === 'guest');

        renderUserList('membersList', members, 'member');
        renderUserList('guestsList', guests, 'guest');
      } catch (error) {
        console.error('Failed to load users:', error);
        document.getElementById('membersList').innerHTML = '<p class="text-red-500">Failed to load users.</p>';
        document.getElementById('guestsList').innerHTML = '<p class="text-red-500">Failed to load users.</p>';
      }
    }

    function renderUserList(containerId, users, type) {
      const container = document.getElementById(containerId);

      if (users.length === 0) {
        container.innerHTML = `<p class="text-warm-gray">No ${type === 'guest' ? 'guests' : 'members'} yet.</p>`;
        return;
      }

      container.innerHTML = users.map(user => `
        <div class="flex items-center justify-between p-4 bg-white rounded-lg">
          <div>
            <p class="font-medium">${escapeHtml(user.firstName)} ${escapeHtml(user.lastName)}</p>
            <p class="text-sm text-warm-gray">${escapeHtml(user.email)}</p>
            ${type === 'member' && user.recoveryEmail ? `<p class="text-xs text-warm-gray">Recovery: ${escapeHtml(user.recoveryEmail)}</p>` : ''}
          </div>
          <div class="flex items-center gap-4">
            ${type === 'member' ? `
            <button data-action="edit-quota" data-email="${escapeHtml(user.email)}" data-quota="${user.quotaMb || 0}"
              class="px-3 py-1 rounded-full text-sm bg-blue-50 text-blue-700 hover:bg-blue-100 cursor-pointer transition-colors" title="Click to edit email quota">
              ${user.quotaMb ? user.quotaMb + ' MB' : 'Unlimited'}
            </button>` : ''}
            <span class="px-3 py-1 rounded-full text-sm ${user.hasPasskey ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800'}">
              ${user.hasPasskey ? 'Active' : 'Pending Passkey'}
            </span>
            <button data-action="delete-user" data-user-id="${escapeHtml(user.id)}" class="text-red-500 hover:text-red-700" title="Removes user from authentication only. Does not delete data from Matrix, Docs, or other apps.">
              Remove Access
            </button>
          </div>
        </div>
      `).join('');

      // Bind click handlers via event delegation
      container.querySelectorAll('[data-action="edit-quota"]').forEach(function(btn) {
        btn.addEventListener('click', function() { editQuota(this.dataset.email, parseInt(this.dataset.quota, 10)); });
      });
      container.querySelectorAll('[data-action="delete-user"]').forEach(function(btn) {
        btn.addEventListener('click', function() { deleteUser(this.dataset.userId); });
      });
    }
    
    // Handle invite form
    document.getElementById('inviteForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const form = e.target;
      
      // Combine username with domain for full email
      const username = document.getElementById('emailUsername').value;
      const domain = document.getElementById('emailDomain').textContent;
      document.getElementById('fullEmail').value = username + domain;
      
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      const messageEl = document.getElementById('formMessage');
      
      try {
        const response = await fetch('/api/invite', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        
        const result = await response.json();
        
        if (response.ok) {
          messageEl.className = 'p-4 rounded-lg bg-green-100 text-green-800';
          messageEl.textContent = 'Invitation sent successfully!';
          messageEl.classList.remove('hidden');
          form.reset();
          loadUsers();
        } else {
          throw new Error(result.error || 'Failed to send invitation');
        }
      } catch (error) {
        messageEl.className = 'p-4 rounded-lg bg-red-100 text-red-800';
        messageEl.textContent = error.message;
        messageEl.classList.remove('hidden');
      }
      
      setTimeout(() => messageEl.classList.add('hidden'), 5000);
    });
    
    // Delete user
    async function deleteUser(userId) {
      if (!confirm('Are you sure you want to delete this user?')) return;
      
      try {
        const response = await fetch(`/api/users/${userId}`, { method: 'DELETE' });
        if (response.ok) {
          loadUsers();
        } else {
          const result = await response.json();
          alert(result.error || 'Failed to delete user');
        }
      } catch (error) {
        alert('Failed to delete user');
      }
    }
    
    // Quota management
    let quotaEditEmail = '';

    function editQuota(email, currentMb) {
      quotaEditEmail = email;
      document.getElementById('quotaModalEmail').textContent = email;
      document.getElementById('quotaInput').value = currentMb;
      document.getElementById('quotaModal').classList.remove('hidden');
    }

    function closeQuotaModal() {
      document.getElementById('quotaModal').classList.add('hidden');
      quotaEditEmail = '';
    }

    async function saveQuota() {
      const quotaMb = parseInt(document.getElementById('quotaInput').value, 10);
      if (isNaN(quotaMb) || quotaMb < 0) {
        alert('Please enter a valid quota (0 or greater)');
        return;
      }
      try {
        const response = await fetch(`/api/users/${encodeURIComponent(quotaEditEmail)}/quota`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ quotaMb }),
        });
        if (!response.ok) {
          const result = await response.json();
          throw new Error(result.error || 'Failed to update quota');
        }
        closeQuotaModal();
        loadUsers();
      } catch (error) {
        alert(error.message);
      }
    }

    async function backfillQuotas() {
      if (!confirm('Apply the default quota to all existing users who currently have no quota set?')) return;
      try {
        const response = await fetch('/api/quota/backfill', { method: 'POST' });
        const result = await response.json();
        if (response.ok) {
          alert(`Backfill complete: ${result.updated} updated, ${result.skipped} skipped`);
          loadUsers();
        } else {
          throw new Error(result.error || 'Backfill failed');
        }
      } catch (error) {
        alert(error.message);
      }
    }

    // Set guest registration link to account portal
    (function() {
      var currentHost = window.location.hostname;
      var accountHost = currentHost.replace(/^admin\./, 'account.');
      var link = document.getElementById('guestRegisterLink');
      if (link) {
        link.href = 'https://' + accountHost + '/register';
      }
    })();

    // Bind static button handlers
    document.getElementById('backfillBtn').addEventListener('click', backfillQuotas);
    document.getElementById('quotaCancelBtn').addEventListener('click', closeQuotaModal);
    document.getElementById('quotaSaveBtn').addEventListener('click', saveQuota);

    // Initial load
    loadUsers();
  </script>
</body>
</html>
