<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/css/fonts.css">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Figtree', system-ui, -apple-system, sans-serif;
      background: #F6F6F3;
      color: #141511;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .bootstrap-container {
      max-width: 420px;
      width: 100%;
      background: #F3E8D6;
      border-radius: 16px;
      padding: 2.5rem;
      box-shadow: 0 10px 30px rgba(20, 21, 17, 0.08);
    }

    .bootstrap-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .bootstrap-title {
      font-family: 'Figtree', sans-serif;
      font-size: 2.25rem;
      font-weight: 600;
      color: #141511;
      margin-bottom: 0.5rem;
    }

    .bootstrap-subtitle {
      color: #6B6B6B;
      font-size: 1rem;
    }

    .info-box {
      background: #f0f2eb;
      border: 1px solid #A7AE8D;
      border-radius: 8px;
      padding: 1rem;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
      color: #141511;
      line-height: 1.5;
    }

    .error-message {
      background: #fee;
      border: 1px solid #fcc;
      color: #A64330;
      padding: 0.75rem 1rem;
      border-radius: 8px;
      margin-bottom: 1.25rem;
      font-size: 0.9rem;
    }

    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      color: #141511;
      font-weight: 500;
      font-size: 0.95rem;
    }

    .form-group input {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 2px solid #e0e0e0;
      border-radius: 8px;
      font-size: 1rem;
      font-family: inherit;
      transition: border-color 0.2s;
    }

    .form-group input:focus {
      outline: none;
      border-color: #A7AE8D;
    }

    .submit-btn {
      width: 100%;
      padding: 1rem;
      background: #A7AE8D;
      color: #F3E8D6;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-family: inherit;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 0.5rem;
    }

    .submit-btn:hover {
      background: #8A9475;
    }

    .back-link {
      text-align: center;
      margin-top: 1.5rem;
    }

    .back-link a {
      color: #6B6B6B;
      text-decoration: none;
      font-size: 0.9rem;
    }

    .back-link a:hover {
      color: #A7AE8D;
    }
  </style>
</head>
<body>
  <div class="bootstrap-container">
    <div class="bootstrap-header">
      <h1 class="bootstrap-title">mothertree</h1>
      <p class="bootstrap-subtitle">First-Time Admin Login</p>
    </div>
    
    <div class="info-box">
      Use this page for your initial login with the temporary password.
      After logging in, you'll be able to access the admin dashboard.
    </div>
    
    <% if (error) { %>
      <div class="error-message"><%= error %></div>
    <% } %>
    
    <form method="POST" action="/bootstrap">
      <div class="form-group">
        <label for="username">Email</label>
        <input type="email" id="username" name="username" required autofocus 
               placeholder="admin@example.org">
      </div>
      
      <div class="form-group">
        <label for="password">Temporary Password</label>
        <input type="password" id="password" name="password" required
               placeholder="Enter your temporary password">
      </div>
      
      <button type="submit" class="submit-btn">Sign In</button>
    </form>
    
    <div class="back-link">
      <a href="/">Back to Home</a>
    </div>

    <% if (privacyPolicyUrl || termsOfUseUrl || acceptableUsePolicyUrl) { %>
    <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #e0e0e0; text-align: center; font-size: 0.75rem; color: #999;">
      <% if (privacyPolicyUrl) { %><a href="<%= privacyPolicyUrl %>" target="_blank" rel="noopener" style="color: #999; text-decoration: none; margin: 0 0.5rem;">Privacy Policy</a><% } %>
      <% if (termsOfUseUrl) { %><a href="<%= termsOfUseUrl %>" target="_blank" rel="noopener" style="color: #999; text-decoration: none; margin: 0 0.5rem;">Terms of Use</a><% } %>
      <% if (acceptableUsePolicyUrl) { %><a href="<%= acceptableUsePolicyUrl %>" target="_blank" rel="noopener" style="color: #999; text-decoration: none; margin: 0 0.5rem;">Acceptable Use Policy</a><% } %>
    </div>
    <% } %>
  </div>
</body>
</html>
