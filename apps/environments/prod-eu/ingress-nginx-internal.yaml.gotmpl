controller:
  config:
    # Dynamic whitelist CIDRs passed from deploy_infra via environment variables
    # Defaults include Tailscale CGNAT range (100.64.0.0/10) for mesh access
    set-real-ip-from: '{{ env "INGRESS_INTERNAL_REAL_IP_FROM" | default "100.64.0.0/10,192.168.0.0/16,10.2.0.0/16" }}'
    whitelist-source-range: '{{ env "INGRESS_INTERNAL_WHITELIST" | default "100.64.0.0/10,192.168.0.0/16,10.2.0.0/16" }}'
