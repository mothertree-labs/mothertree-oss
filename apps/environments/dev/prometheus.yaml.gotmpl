prometheus:
  # Dev-only overrides. Requests raised to match actual usage (~1156Mi observed)
  # so the scheduler accurately represents node pressure.
  prometheusSpec:
    # Dev-only: avoid consuming a Linode block volume attachment.
    # Single-node dev clusters can hit Linode's max attached volume limit when multiple tenants are deployed.
    storageSpec:
      emptyDir: {}
    retention: 7d
    resources:
      requests:
        cpu: 100m
        memory: 1280Mi
      limits:
        memory: 3Gi
  ingress:
    hosts:
      - 'prometheus.internal.{{ env "INFRA_ENV_DNS_LABEL" }}.{{ env "INFRA_DOMAIN" }}'
    tls:
      - secretName: prometheus-tls
        hosts:
          - 'prometheus.internal.{{ env "INFRA_ENV_DNS_LABEL" }}.{{ env "INFRA_DOMAIN" }}'

grafana:
  adminPassword: '{{ env "TF_VAR_grafana_admin_password" | default "changeme" }}'
  # Match prod base values — actual usage ~260Mi, was exceeding the 256Mi limit.
  resources:
    requests:
      cpu: 50m
      memory: 320Mi
    limits:
      memory: 512Mi
  ingress:
    hosts:
      - 'grafana.internal.{{ env "INFRA_ENV_DNS_LABEL" }}.{{ env "INFRA_DOMAIN" }}'
    tls:
      - secretName: grafana-tls
        hosts:
          - 'grafana.internal.{{ env "INFRA_ENV_DNS_LABEL" }}.{{ env "INFRA_DOMAIN" }}'

# Disable alerts that are acceptable in dev
defaultRules:
  disabled:
    KubeMemoryOvercommit: true

alertmanager:
  ingress:
    hosts:
      - 'alertmanager.internal.{{ env "INFRA_ENV_DNS_LABEL" }}.{{ env "INFRA_DOMAIN" }}'
    tls:
      - secretName: alertmanager-tls
        hosts:
          - 'alertmanager.internal.{{ env "INFRA_ENV_DNS_LABEL" }}.{{ env "INFRA_DOMAIN" }}'
  # AlertManager configuration for dev alerting.
  # Dev has no SES credentials and no in-cluster SMTP relay (infra-Postfix is
  # inbound-MX-only since PR-4), so email_configs are dropped; alerts go to
  # Matrix via webhook. Same pattern as prod-eu.
  config:
    route:
      receiver: 'matrix-alerts'
      group_by: ['alertname', 'severity', 'namespace']
      group_wait: 30s
      group_interval: 5m
      repeat_interval: 4h
      routes:
        # Drop noisy internal alerts
        - match:
            alertname: InfoInhibitor
          receiver: 'null'
        # Dev runs single PgBouncer pool — degraded state is expected
        - match:
            alertname: PgBouncerDegraded
          receiver: 'null'
        # Critical alerts: notify Matrix immediately and more frequently
        - match:
            severity: critical
          receiver: 'matrix-alerts'
          repeat_interval: 1h
    receivers:
      - name: 'null'
      - name: 'matrix-alerts'
        webhook_configs:
          - url: 'http://matrix-alertmanager.{{ env "NS_MONITORING" }}.svc.cluster.local:3000/alerts/{{ env "ALERTMANAGER_MATRIX_ROOM_ID" | default "!room:matrix.example.org" }}'
            send_resolved: true
    inhibit_rules:
      # Don't send warning alerts if critical alert is already firing
      - source_match:
          severity: 'critical'
        target_match:
          severity: 'warning'
        equal: ['alertname', 'namespace']
