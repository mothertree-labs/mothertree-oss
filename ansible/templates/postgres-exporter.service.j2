[Unit]
Description=Prometheus PostgreSQL Exporter
After=postgresql.service tailscaled.service
Wants=postgresql.service

[Service]
Type=simple
User=postgres_exporter
Group=postgres_exporter
Environment=DATA_SOURCE_NAME=postgresql://postgres_exporter:{{ postgres_exporter_password }}@localhost:5432/postgres?sslmode=disable
ExecStart=/usr/local/bin/postgres_exporter \
  --web.listen-address={{ postgres_exporter_listen | default("0.0.0.0:9187") }}
Restart=always
RestartSec=5

ProtectSystem=strict
ProtectHome=true
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
