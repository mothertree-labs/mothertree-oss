# PostgreSQL configuration — managed by Ansible
# Only settings that differ from defaults are listed here.

# ---------------------------------------------------------------------------
# Connection
# ---------------------------------------------------------------------------
# Listen on all interfaces. pg_hba.conf restricts to Tailscale CGNAT range.
# See design doc: binding to a specific Tailscale IP would require a post-join
# reconfiguration step since the IP isn't known until after tailnet join.
listen_addresses = '0.0.0.0'
port = 5432
max_connections = {{ pg_max_connections | default(200) }}

# ---------------------------------------------------------------------------
# Memory
# ---------------------------------------------------------------------------
shared_buffers = '{{ pg_shared_buffers | default("256MB") }}'
effective_cache_size = '{{ pg_effective_cache_size | default("512MB") }}'
work_mem = '{{ pg_work_mem | default("4MB") }}'
maintenance_work_mem = '{{ pg_maintenance_work_mem | default("128MB") }}'

# ---------------------------------------------------------------------------
# WAL / Archiving (pgBackRest)
# ---------------------------------------------------------------------------
wal_level = replica
archive_mode = on
archive_command = 'pgbackrest --stanza={{ pgbackrest_stanza }} archive-push %p'
max_wal_senders = 3

# ---------------------------------------------------------------------------
# Checkpoints
# ---------------------------------------------------------------------------
checkpoint_completion_target = 0.9
min_wal_size = '256MB'
max_wal_size = '1GB'

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log_destination = 'stderr'
logging_collector = on
log_directory = 'log'
log_filename = 'postgresql-%a.log'
log_truncate_on_rotation = on
log_rotation_age = 1d
log_rotation_size = 0
log_min_duration_statement = 1000
log_line_prefix = '%m [%p] %q%u@%d '

# ---------------------------------------------------------------------------
# Data directory (symlinked to persistent volume)
# ---------------------------------------------------------------------------
data_directory = '/var/lib/postgresql/{{ pg_version }}/main'

# ---------------------------------------------------------------------------
# Stats / Monitoring
# ---------------------------------------------------------------------------
shared_preload_libraries = 'pg_stat_statements'
pg_stat_statements.track = all
